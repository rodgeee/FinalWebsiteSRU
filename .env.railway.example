# Railway service variables (set in Dashboard → Variables)

APP_ENV=prod
APP_DEBUG=0
# One long random string only — no spaces, no quotes, no text like "(32+ characters)"
APP_SECRET=a7f3c9e2b1d84f6a0e5c8b2d9f1a4e7c6b3d8f0a2e5c9b1d4f7a8e3c6b0d1

# Open / on admin login (also automatic for *.up.railway.app hosts)
APP_ROOT_TO_ADMIN=1

# Link MySQL service to this app — Railway may inject MYSQL_URL; entrypoint maps it to DATABASE_URL.
# Or set DATABASE_URL manually (must include serverVersion=8.0.32):
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=8.0.32&charset=utf8mb4

DEFAULT_URI=https://YOUR-SERVICE.up.railway.app

MAILER_DSN=null://null
MAILER_FROM_ADDRESS=noreply@example.com
MESSENGER_TRANSPORT_DSN=sync://
CORS_ALLOW_ORIGIN=^.*$

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

# Storefront: /landingpage shows products ( / still opens admin when APP_ROOT_TO_ADMIN=1 ).
# On each deploy the app seeds 5 demo products if the catalog is empty.
# For YOUR local data: run scripts/export-data-for-railway.ps1, copy output to data/railway-import.sql,
# then either commit that file for one deploy or import it in Railway → MySQL.

# --- Admin login on Railway ---
# Option A (recommended): set these on the app service, redeploy once, then remove the password var.
ENSURE_DEFAULT_ADMIN=1
BOOTSTRAP_ADMIN_EMAIL=admin@shoesrus.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
#
# Option B: import auth-export.sql (scripts/export-auth-for-railway.ps1) — password hash must match local.
# Option C: Railway shell: php bin/console app:create-admin --email=admin@shoesrus.local --password='Admin@12345' --env=prod
# 2. Staff must be email-verified to log in:
#    php bin/console app:verify-staff-for-login
# 3. Redeploy after Dockerfile session fix if you saw 500 after login.

# --- Import YOUR local database rows ---
# 1. .\scripts\export-data-for-railway.ps1  →  data\railway-import.sql
# 2. Redeploy (auto-import when products table is empty) OR Railway MySQL → import SQL file.
# 3. Product images in public/uploads/products/ are included in the Docker image if present in the repo.
