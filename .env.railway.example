# Railway service variables (set in Dashboard → Variables)

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=generate-a-long-random-string

# From Railway MySQL plugin (use exact version, e.g. 8.0.32 not 8)
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=8.0.32&charset=utf8mb4

DEFAULT_URI=https://YOUR-SERVICE.up.railway.app

MAILER_DSN=null://null
MAILER_FROM_ADDRESS=noreply@example.com
MESSENGER_TRANSPORT_DSN=sync://
CORS_ALLOW_ORIGIN=^.*$

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

# Optional: insert 5 demo products when the products table is empty
SEED_DEMO_PRODUCTS=1

# --- Import YOUR local products instead of demo seed ---
# 1. Export from local MySQL (Docker):
#    docker compose exec mysql mysqldump -u sru_user -p sru_db products stocks > products-export.sql
# 2. Import into Railway MySQL (use Railway → MySQL → Connect / credentials).
# 3. Also copy public/uploads/products/ if you use uploaded images.
