# Railway service variables (set in Dashboard → Variables)

APP_ENV=prod
APP_DEBUG=0
# One long random string only — no spaces, no quotes, no text like "(32+ characters)"
APP_SECRET=a7f3c9e2b1d84f6a0e5c8b2d9f1a4e7c6b3d8f0a2e5c9b1d4f7a8e3c6b0d1

# Open / on admin login (also automatic for *.up.railway.app hosts)
APP_ROOT_TO_ADMIN=1

# Link MySQL service to this app (required). Railway injects MYSQL_URL or MYSQLHOST/MYSQLUSER/etc.
# Do NOT set DATABASE_URL to 127.0.0.1 — entrypoint rejects localhost URLs.
# Optional manual override (must not be localhost):
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=8.0.32&charset=utf8mb4

DEFAULT_URI=https://YOUR-SERVICE.up.railway.app

# Google OAuth (required for "Sign in with Google" on admin/staff login and mobile API).
# Use the same Web client as local .env. Register BOTH redirect URIs in Google Cloud Console:
#   https://YOUR-SERVICE.up.railway.app/connect/google/check
#   https://YOUR-SERVICE.up.railway.app/adminls/connect/google/check
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
# Optional — entrypoint sets this from DEFAULT_URI if omitted:
# GOOGLE_CALLBACK_URL=https://YOUR-SERVICE.up.railway.app/connect/google/check

# Required for staff/customer verification emails (null://null = emails are discarded).
# Gmail example (use an App Password, not your normal password):
# MAILER_DSN=gmail+smtp://YOUR_GMAIL@gmail.com:APP_PASSWORD@smtp.gmail.com:587
# Brevo example:
# MAILER_DSN=brevo+smtp://apikey:YOUR_BREVO_SMTP_KEY@smtp-relay.brevo.com:587
MAILER_DSN=null://null
MAILER_FROM_ADDRESS=noreply@yourdomain.com
MAILER_FROM_NAME="Shoes R' Us"
MESSENGER_TRANSPORT_DSN=sync://
CORS_ALLOW_ORIGIN=^.*$

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Must stay empty — Docker/Railway JWT keys are generated without encryption.
JWT_PASSPHRASE=

# Storefront: /landingpage shows products ( / still opens admin when APP_ROOT_TO_ADMIN=1 ).
# Full local DB embedded in src/DataFixtures/FixtureLoader.php (regenerate: php scripts/generate-fixture-data.php).
# LOAD_APP_FIXTURES=1 purges all app tables then loads fixtures — use only once, then unset the variable.
# Leaving it on wipes data on every deploy. Demo products seed when the catalog is empty if fixtures are off.

# --- Admin login on Railway ---
# Option A (recommended): set these on the app service, redeploy once, then remove the password var.
ENSURE_DEFAULT_ADMIN=1
BOOTSTRAP_ADMIN_EMAIL=admin@shoesrus.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
#
# Staff dashboard (same /adminls/login; lands on orders, not full admin dashboard):
ENSURE_DEFAULT_STAFF=1
BOOTSTRAP_STAFF_EMAIL=staff@shoesrus.local
BOOTSTRAP_STAFF_PASSWORD=Staff@12345
#
# Option B: import auth-export.sql (scripts/export-auth-for-railway.ps1) — password hash must match local.
# Option C: Railway shell: php bin/console app:create-admin --email=admin@shoesrus.local --password='Admin@12345' --env=prod
# 2. Staff must be email-verified to log in:
#    php bin/console app:verify-staff-for-login
# 3. Redeploy after Dockerfile session fix if you saw 500 after login.

# --- Import YOUR local database rows ---
# 1. .\scripts\export-data-for-railway.ps1  →  data\railway-import.sql
# 2. Redeploy (auto-import when products table is empty) OR Railway MySQL → import SQL file.
# 3. Product images in public/uploads/products/ are included in the Docker image if present in the repo.
