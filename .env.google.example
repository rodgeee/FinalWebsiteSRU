# Copy these lines into .env or .env.local — see docs/google-oauth.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:8000/connect/google/check
# Optional: separate mobile OAuth client IDs (tokeninfo aud must match one of these)
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
