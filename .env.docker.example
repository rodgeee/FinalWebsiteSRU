# Copy to .env in the project root (or merge with your existing .env) for docker compose.

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=srusystem
MYSQL_USER=srusystem
MYSQL_PASSWORD=srusystem

APP_PORT=8000
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=ChangeMeInProduction

# Set to 1 on first run to apply Doctrine migrations automatically
RUN_MIGRATIONS=1
