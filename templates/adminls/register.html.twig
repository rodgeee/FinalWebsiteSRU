{% extends 'base.html.twig' %}

{% block title %}Create Admin Account • Shoes R' Us{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    :root {
      --bg: #f5f7fb;
      --border: #e5e7eb;
      --text: #1a1a1a;
      --muted: #6b7280;
      --brand: #0077FF;
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      background: var(--bg);
      font-family: sans-serif;
      color: var(--text);
    }
    h1, h2, h3 {
      font-family: "Sora", sans-serif;
      font-weight: 700;
    }
    .auth-shell {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .auth-card {
      background: #fff;
      border: 1px solid var(--border);
      box-shadow: 0 10px 40px rgba(0,0,0,0.08);
      border-radius: 16px;
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      max-width: 1100px;
      width: 100%;
      overflow: hidden;
    }
    .auth-left {
      position: relative;
      overflow: hidden;
      background: #0f5bd8;
      color: #f8fbff;
      padding: 32px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .auth-left::before {
      content: "";
      position: absolute;
      inset: -20px;
      background-image: url("{{ asset('img/pattern1.png') }}");
      background-repeat: repeat;
      background-size: 900px auto;
      opacity: 0.42;
      animation: patternScroll 28s linear infinite;
      pointer-events: none;
    }
    .auth-left > * { position: relative; z-index: 1; }
    .auth-left .logo {
      height: 64px;
      width: auto;
      display: block;
      margin-bottom: 16px;
    }
    .auth-left h1 {
      margin: 0 0 8px 0;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .auth-left p {
      margin: 0;
      color: #dbeafe;
      font-size: 14px;
    }
    .auth-footnote {
      margin-top: 32px;
      font-size: 12px;
      color: #dbeafe;
    }
    .auth-right {
      padding: 36px 40px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .brand-logo { height: 54px; width: auto; }
    .brand-text h1 {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
    }
    .brand-text p {
      margin: 0;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 600;
    }
    .auth-title {
      margin: 8px 0 0 0;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .auth-sub {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
    }
    .auth-alert {
      padding: 12px 14px;
      border-radius: 10px;
      font-size: 14px;
      border: 1px solid #fca5a5;
      background: #fef2f2;
      color: #b91c1c;
    }
    .auth-success {
      padding: 12px 14px;
      border-radius: 10px;
      font-size: 14px;
      border: 1px solid #bbf7d0;
      background: #ecfdf3;
      color: #166534;
    }
    .auth-form {
      margin-top: 8px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .auth-field label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 6px;
    }
    .auth-input {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 14px;
      font-size: 14px;
      transition: border-color 150ms, box-shadow 150ms;
      background: #fff;
    }
    .auth-input:focus {
      outline: none;
      border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(0,119,255,0.15);
    }
    .auth-button {
      width: 100%;
      border: none;
      border-radius: 12px;
      padding: 12px 14px;
      background: var(--brand);
      color: #fff;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      transition: transform 120ms ease, box-shadow 120ms ease;
      box-shadow: 0 10px 25px rgba(0,119,255,0.15);
    }
    .auth-button:hover { transform: translateY(-1px); box-shadow: 0 12px 28px rgba(0,119,255,0.2); }
    .auth-button:active { transform: translateY(0); }
    .auth-footer {
      text-align: center;
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }
    @keyframes patternScroll {
      from { background-position: 0 0; }
      to { background-position: -480px 480px; }
    }
    @media (max-width: 960px) {
      .auth-card { grid-template-columns: 1fr; }
      .auth-left { display: none; }
    }
  </style>
{% endblock %}

{% block body %}
<div class="auth-shell">
  <div class="auth-card">
    <div class="auth-left">
      <div>
        <img src="{{ asset('img/shoes-r-us-logo.png') }}" alt="Shoes R' Us" class="logo">
        <h1>Welcome to the team!</h1>
        <p>Create your admin account to manage products, releases, and orders efficiently.</p>
      </div>
      <div class="auth-footnote">© {{ "now"|date('Y') }} Shoes R' Us. All rights reserved.</div>
    </div>
    <div class="auth-right">
      <div class="brand">
        <img src="{{ asset('img/shoes-r-us-logo.png') }}" alt="Shoes R' Us" class="brand-logo">
        <div class="brand-text">
          <h1>Shoes R' Us</h1>
          <p>Admin</p>
        </div>
      </div>

      <h2 class="auth-title">Create Admin Account</h2>
      <p class="auth-sub">Strong passwords help keep accounts secure.</p>
      
      {% if error %}
        <div class="auth-alert">
          {{ error }}
        </div>
      {% endif %}
      
      {% for message in app.flashes('success') %}
        <div class="auth-success">
          {{ message }}
        </div>
      {% endfor %}
      
      <form method="post" action="{{ path('adminls_register') }}" class="auth-form" data-turbo="false">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('submit') }}" data-controller="csrf-protection">
        <div class="auth-field">
          <label for="fullName">Full Name</label>
          <input type="text" id="fullName" name="fullName" class="auth-input" placeholder="Your Full Name" value="{{ formData.fullName }}" required>
        </div>
        
        <div class="auth-field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" class="auth-input" placeholder="you@example.com" value="{{ formData.email }}" required inputmode="email" autocomplete="email">
        </div>
        
        <div class="auth-field">
          <label for="password">Password</label>
          <div style="position:relative;">
            <input type="password" id="password" name="password" class="auth-input" placeholder="••••••••" value="{{ formData.password }}" required minlength="8" autocomplete="new-password" pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}" style="padding-right:44px;">
            <button type="button" id="togglePassword" aria-label="Show password" title="Show password" style="position:absolute; right:8px; top:0; bottom:0; margin:auto 0; padding:0; width:36px; height:100%; display:inline-flex; align-items:center; justify-content:center; background:transparent; color:#666; border:none; box-shadow:none; border-radius:8px; cursor:pointer;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 18 18"/><path d="M10.58 10.58a2 2 0 1 0 2.83 2.83"/><path d="M16.68 16.68A9.86 9.86 0 0 1 12 20c-7 0-11-8-11-8a18.5 18.5 0 0 1 5.06-5.94"/><path d="M14.12 5.1A9.77 9.77 0 0 1 12 4c-7 0-11 8-11 8a18.43 18.43 0 0 0 5.63 6.19"/></svg>
            </button>
          </div>
          <div id="passwordChecklistContainer" style="display:none; opacity:0; transform:translateY(-4px); transition:opacity 150ms ease, transform 150ms ease; margin-top:8px;">
            <div style="font-size:13px; color:#444; margin-bottom:6px;">Password must have:</div>
            <ul id="passwordChecklist" style="list-style:none; padding-left:0; margin:0; font-size:13px; color:#666; display:grid; gap:4px;">
              <li data-criterion="length"><span data-indicator>•</span> at least 8 characters</li>
              <li data-criterion="lower"><span data-indicator>•</span> a lowercase letter</li>
              <li data-criterion="upper"><span data-indicator>•</span> an uppercase letter</li>
              <li data-criterion="number"><span data-indicator>•</span> a number</li>
              <li data-criterion="symbol"><span data-indicator>•</span> a symbol (e.g., ! @ # $ % _)</li>
              <li data-criterion="match"><span data-indicator>•</span> passwords match</li>
            </ul>
          </div>
        </div>
        
        <div class="auth-field">
          <label for="confirmPassword">Confirm Password</label>
          <div style="position:relative;">
            <input type="password" id="confirmPassword" name="confirmPassword" class="auth-input" placeholder="••••••••" value="{{ formData.confirmPassword }}" required minlength="8" autocomplete="new-password" style="padding-right:44px;">
            <button type="button" id="toggleConfirmPassword" aria-label="Show password" title="Show password" style="position:absolute; right:8px; top:0; bottom:0; margin:auto 0; padding:0; width:36px; height:100%; display:inline-flex; align-items:center; justify-content:center; background:transparent; color:#666; border:none; box-shadow:none; border-radius:8px; cursor:pointer;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 18 18"/><path d="M10.58 10.58a2 2 0 1 0 2.83 2.83"/><path d="M16.68 16.68A9.86 9.86 0 0 1 12 20c-7 0-11-8-11-8a18.5 18.5 0 0 1 5.06-5.94"/><path d="M14.12 5.1A9.77 9.77 0 0 1 12 4c-7 0-11 8-11 8a18.43 18.43 0 0 0 5.63 6.19"/></svg>
            </button>
          </div>
        </div>
        
        <button type="submit" class="auth-button">Create Account</button>
      </form>

      <p class="auth-footer">Already have an account? <a href="{{ path('adminls_login') }}" class="auth-link" data-turbo="false">Login</a></p>
    </div>
  </div>
</div>
<script>
  (function(){
    const pwd = document.getElementById('password');
    const cpw = document.getElementById('confirmPassword');
    const list = document.getElementById('passwordChecklist');
    const listContainer = document.getElementById('passwordChecklistContainer');
    if (!pwd || !cpw || !list) return;

    const criteria = {
      length: v => v.length >= 8,
      lower: v => /[a-z]/.test(v),
      upper: v => /[A-Z]/.test(v),
      number: v => /\d/.test(v),
      symbol: v => /[^A-Za-z0-9]/.test(v),
      match: () => pwd.value.length > 0 && pwd.value === cpw.value,
    };

    function updateChecklist(){
      const value = pwd.value;
      const status = {
        length: criteria.length(value),
        lower: criteria.lower(value),
        upper: criteria.upper(value),
        number: criteria.number(value),
        symbol: criteria.symbol(value),
        match: criteria.match(),
      };
      list.querySelectorAll('li').forEach(li => {
        const key = li.getAttribute('data-criterion');
        const ok = !!status[key];
        li.style.color = ok ? '#15803d' : '#666';
        const indicator = li.querySelector('[data-indicator]');
        if (indicator) indicator.textContent = ok ? '✓' : '•';
      });
      // Provide custom validity message instead of generic browser message
      const unmet = Object.entries(status).filter(([k, v]) => !v && k !== 'match').map(([k]) => k);
      let message = '';
      if (unmet.length > 0) {
        const parts = [];
        if (unmet.includes('length')) parts.push('at least 8 characters');
        if (unmet.includes('lower')) parts.push('a lowercase letter');
        if (unmet.includes('upper')) parts.push('an uppercase letter');
        if (unmet.includes('number')) parts.push('a number');
        if (unmet.includes('symbol')) parts.push('a symbol');
        message = 'Password must include: ' + parts.join(', ') + '.';
      } else if (!status.match && cpw.value.length > 0) {
        message = 'Passwords do not match.';
      }
      pwd.setCustomValidity(message);
      // Also reflect mismatch on confirm field
      cpw.setCustomValidity(status.match || cpw.value.length === 0 ? '' : 'Passwords do not match.');
    }

    pwd.addEventListener('input', updateChecklist);
    cpw.addEventListener('input', updateChecklist);
    updateChecklist();

    function shouldKeepOpen(){
      return document.activeElement === pwd || pwd.value.length > 0;
    }

    function showChecklist(){
      if (!listContainer) return;
      listContainer.style.display = 'block';
      requestAnimationFrame(() => {
        listContainer.style.opacity = '1';
        listContainer.style.transform = 'translateY(0)';
      });
    }

    function hideChecklist(){
      if (!listContainer) return;
      if (shouldKeepOpen()) return;
      listContainer.style.opacity = '0';
      listContainer.style.transform = 'translateY(-4px)';
      setTimeout(() => {
        if (!shouldKeepOpen()) {
          listContainer.style.display = 'none';
        }
      }, 150);
    }

    pwd.addEventListener('focus', showChecklist);
    pwd.addEventListener('blur', () => setTimeout(hideChecklist, 100));
    cpw.addEventListener('focus', hideChecklist);
    cpw.addEventListener('blur', hideChecklist);
    document.addEventListener('click', (e) => {
      if (![pwd, cpw].includes(document.activeElement) && !listContainer.contains(e.target)) {
        hideChecklist();
      }
    });
    if (pwd.value || cpw.value) showChecklist();

    function toggleInputType(input, btn){
      if (!input || !btn) return;
      const isHidden = input.getAttribute('type') === 'password';
      input.setAttribute('type', isHidden ? 'text' : 'password');
      btn.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
      btn.setAttribute('title', isHidden ? 'Hide password' : 'Show password');
      btn.innerHTML = isHidden
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"></path><circle cx="12" cy="12" r="3"></circle></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 18 18"/><path d="M10.58 10.58a2 2 0 1 0 2.83 2.83"/><path d="M16.68 16.68A9.86 9.86 0 0 1 12 20c-7 0-11-8-11-8a18.5 18.5 0 0 1 5.06-5.94"/><path d="M14.12 5.1A9.77 9.77 0 0 1 12 4c-7 0-11 8-11 8a18.43 18.43 0 0 0 5.63 6.19"/></svg>';
    }
    const toggle = document.getElementById('togglePassword');
    const toggle2 = document.getElementById('toggleConfirmPassword');
    toggle?.addEventListener('click', () => toggleInputType(pwd, toggle));
    toggle2?.addEventListener('click', () => toggleInputType(cpw, toggle2));
  })();
</script>
{% endblock %}