{% extends 'dashboard/index.html.twig' %}

{% block title %}Edit Product • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[1200px] p-4 sm:p-6">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-2xl font-semibold">Edit product</h1>
      <div class="flex items-center gap-2">
        <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all" title="Return to dashboard" aria-label="Return to dashboard">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline><path d="M20 12H10"></path></svg>
          <span class="sr-only">Dashboard</span>
        </a>
        <a href="{{ path('admin_products_index') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all">Back</a>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-white p-4 shadow-card">
      {{ form_start(form) }}
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="sm:col-span-1">{{ form_row(form.Name) }}</div>
          <div class="sm:col-span-1">{{ form_row(form.Color) }}</div>
          <div class="sm:col-span-1">{{ form_row(form.Size) }}</div>
          <div class="sm:col-span-1">{{ form_row(form.Stocks) }}</div>
          <div class="sm:col-span-1">{{ form_row(form.Price) }}</div>
          <div class="sm:col-span-2">{{ form_row(form.Description) }}</div>
          <div class="sm:col-span-2">{{ form_row(form.Image) }}</div>
        </div>
        <div class="mt-4 flex items-center gap-2">
          <button class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-md transition-all hover:shadow-lg" type="submit">Save changes</button>
          <a class="text-textMuted" href="{{ path('admin_products_index') }}">Cancel</a>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}


