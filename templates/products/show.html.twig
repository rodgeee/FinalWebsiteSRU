{% extends 'dashboard/index.html.twig' %}

{% block title %}Product Details • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[1200px] p-4 sm:p-6">
    <div class="mb-4 flex items-center justify-between">
      <h1 class="text-2xl font-semibold">Product #{{ product.id }}</h1>
      <div class="space-x-2">
        <a href="{{ path('admin_stocks_index') }}" class="rounded-xl border border-border px-3 py-2 text-sm font-semibold text-gray-800" aria-label="Back to stocks" title="Back to stocks">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline><path d="M20 12H10"></path></svg>
        </a>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-white p-4 shadow-card">
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <dt class="text-xs uppercase text-textMuted">Name</dt>
          <dd class="text-sm">{{ product.name }}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase text-textMuted">Color</dt>
          <dd class="text-sm">{{ product.color }}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase text-textMuted">Size</dt>
          <dd class="text-sm">{{ product.size }}</dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs uppercase text-textMuted">Stock entries</dt>
          <dd class="text-sm">
            {% set stockCount = product.stocks|length %}
            {% if stockCount == 0 %}
              <span class="text-textMuted">No stock entries linked.</span>
            {% else %}
              <div class="overflow-x-auto mt-2">
                <table class="min-w-full text-sm border border-border rounded-lg">
                  <thead>
                    <tr class="text-left text-xs uppercase tracking-wider text-textMuted">
                      <th class="border-b border-border px-3 py-2">ID</th>
                      <th class="border-b border-border px-3 py-2">Quantity</th>
                      <th class="border-b border-border px-3 py-2">Updated</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for stock in product.stocks %}
                      <tr>
                        <td class="border-b border-border px-3 py-2">{{ stock.id }}</td>
                        <td class="border-b border-border px-3 py-2">{{ stock.quantity ?? '—' }}</td>
                        <td class="border-b border-border px-3 py-2">{{ stock.updatedAt ? stock.updatedAt|date('Y-m-d H:i') : '—' }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </dd>
        </div>
        <div>
          <dt class="text-xs uppercase text-textMuted">Price</dt>
          <dd class="text-sm">{{ product.price ? ('₱' ~ product.price) : '—' }}</dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-xs uppercase text-textMuted">Description</dt>
          <dd class="text-sm">{{ product.description }}</dd>
        </div>
      </dl>
    </div>

    {% if is_granted('ROLE_ADMIN') %}
      <form class="mt-4" method="post" action="{{ path('admin_products_delete', {id: product.id}) }}" onsubmit="return confirm('Delete this product?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
        <button class="rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white" type="submit" aria-label="Delete" title="Delete">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path></svg>
        </button>
      </form>
    {% else %}
      <button type="button" class="mt-4 rounded-xl bg-red-100 px-4 py-2 text-sm font-semibold text-red-600 cursor-not-allowed" title="Delete (admin only)" onclick="alert('You can only modify your added stock, please contact the admin for change requests');">
        Delete (admin only)
      </button>
    {% endif %}

  </div>
</div>
{% endblock %}


