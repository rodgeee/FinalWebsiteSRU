{% extends 'public/_layout.html.twig' %}

{% block title %}Releases &amp; Raffle • Shoes R' Us{% endblock %}

{% block body_class %}lp-home lp-releases-page{% endblock %}

{% block public_page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/releases-page.css') }}">
{% endblock %}

{% block public_page_body %}
    <main class="lp-releases" data-lp-releases>
        <header class="lp-releases__head">
            <h1 class="lp-releases__title">Releases &amp; Raffle</h1>
            <button
                type="button"
                class="lp-releases__filters-toggle"
                data-lp-releases-filters-toggle
                aria-expanded="false"
                aria-controls="lp-releases-filters"
            >
                <span class="lp-releases__filters-toggle-label" data-lp-releases-filters-label>Show Filters</span>
                <svg class="lp-releases__filters-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7h16M7 12h10M10 17h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="8" cy="7" r="1.5" fill="currentColor"/>
                    <circle cx="14" cy="12" r="1.5" fill="currentColor"/>
                    <circle cx="12" cy="17" r="1.5" fill="currentColor"/>
                </svg>
            </button>
        </header>

        <div id="lp-releases-filters" class="lp-releases__filters" data-lp-releases-filters hidden>
            <fieldset class="lp-releases__filter-group">
                <legend class="lp-releases__filter-legend">Brand</legend>
                <div class="lp-releases__filter-options">
                    <label class="lp-releases__filter-chip">
                        <input type="checkbox" name="brand" value="" data-lp-releases-brand-all checked>
                        <span>All</span>
                    </label>
                    {% for brand in brandFilters %}
                        <label class="lp-releases__filter-chip">
                            <input type="checkbox" name="brand" value="{{ brand }}" data-lp-releases-brand>
                            <span>{{ brand }}</span>
                        </label>
                    {% endfor %}
                </div>
            </fieldset>
            <fieldset class="lp-releases__filter-group">
                <legend class="lp-releases__filter-legend">Sort</legend>
                <select class="lp-releases__sort" data-lp-releases-sort aria-label="Sort products">
                    <option value="newest">Newest first</option>
                    <option value="price-asc">Price: low to high</option>
                    <option value="price-desc">Price: high to low</option>
                    <option value="name">Name A–Z</option>
                </select>
            </fieldset>
        </div>

        {% if productRows is empty %}
            <p class="lp-releases__empty">No new releases yet. Check back soon.</p>
        {% else %}
            <div class="lp-releases__grid" data-lp-releases-grid>
                {% for row in productRows %}
                    {% set p = row.product %}
                    <article
                        class="lp-releases-card"
                        data-lp-releases-card
                        data-product-id="{{ p.id }}"
                        data-brand="{{ row.filterBrand|e('html_attr') }}"
                        data-name="{{ row.displayName|e('html_attr') }}"
                        data-price="{{ p.price ?? 0 }}"
                    >
                        <div class="lp-releases-card__inner">
                            <button type="button" class="lp-releases-card__wishlist" aria-label="Save {{ p.name }} to wishlist" onclick="event.preventDefault(); event.stopPropagation();">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M12 20.25l-1.45-1.32C5.4 14.36 2 11.28 2 7.5 2 5 4 3 6.5 3c1.74 0 3.41 1.01 4.22 2.44C11.09 4.01 12.76 3 14.5 3 17 3 19 5 19 7.5c0 3.78-3.4 6.86-8.55 11.43L12 20.25z" stroke="currentColor" stroke-width="1.6"/>
                                </svg>
                            </button>
                            <a href="{{ path('public_product_show', { id: p.id }) }}" class="lp-releases-card__link" data-turbo-frame="_top">
                            <div class="lp-releases-card__media">
                                {% set primary = p.primaryImage %}
                                {% if primary %}
                                    {% if primary starts with 'http' %}
                                        <img src="{{ primary }}" alt="{{ p.name }}" loading="lazy" decoding="async">
                                    {% else %}
                                        <img src="{{ asset(primary) }}" alt="{{ p.name }}" loading="lazy" decoding="async">
                                    {% endif %}
                                {% else %}
                                    <img src="{{ asset('img/shoes-r-us-logo.png') }}" alt="{{ p.name }}" loading="lazy" decoding="async">
                                {% endif %}
                            </div>
                            <div class="lp-releases-card__body">
                                {% if row.brandLabel %}
                                    <p class="lp-releases-card__brand">{{ row.brandLabel }}</p>
                                {% endif %}
                                <p class="lp-releases-card__name">{{ row.displayName }}</p>
                                <p class="lp-releases-card__price">
                                    {{ p.price ? '₱' ~ p.price|number_format(0, '.', ',') : '—' }}
                                </p>
                            </div>
                            </a>
                        </div>
                    </article>
                {% endfor %}
            </div>
            <p class="lp-releases__no-match" data-lp-releases-no-match hidden>No products match your filters.</p>
        {% endif %}
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function initLpReleases() {
                const root = document.querySelector('[data-lp-releases]');
                if (!root || root.dataset.lpReleasesInit === '1') {
                    return;
                }

                const grid = root.querySelector('[data-lp-releases-grid]');
                const toggle = root.querySelector('[data-lp-releases-filters-toggle]');
                const filtersPanel = root.querySelector('[data-lp-releases-filters]');
                const filtersLabel = root.querySelector('[data-lp-releases-filters-label]');
                const sortSelect = root.querySelector('[data-lp-releases-sort]');
                const brandAll = root.querySelector('[data-lp-releases-brand-all]');
                const brandInputs = root.querySelectorAll('[data-lp-releases-brand]');
                const noMatch = root.querySelector('[data-lp-releases-no-match]');

                if (!grid) {
                    return;
                }

                root.dataset.lpReleasesInit = '1';

                const cards = Array.from(grid.querySelectorAll('[data-lp-releases-card]'));

                toggle?.addEventListener('click', function () {
                    const open = filtersPanel.hasAttribute('hidden');
                    if (open) {
                        filtersPanel.removeAttribute('hidden');
                        toggle.setAttribute('aria-expanded', 'true');
                        if (filtersLabel) {
                            filtersLabel.textContent = 'Hide Filters';
                        }
                    } else {
                        filtersPanel.setAttribute('hidden', '');
                        toggle.setAttribute('aria-expanded', 'false');
                        if (filtersLabel) {
                            filtersLabel.textContent = 'Show Filters';
                        }
                    }
                });

                function selectedBrands() {
                    if (brandAll?.checked) {
                        return null;
                    }
                    const selected = [];
                    brandInputs.forEach(function (input) {
                        if (input.checked) {
                            selected.push(input.value);
                        }
                    });
                    return selected.length ? selected : null;
                }

                function applyFilters() {
                    const brands = selectedBrands();
                    let visible = 0;

                    cards.forEach(function (card) {
                        const brand = card.getAttribute('data-brand') || '';
                        const show = brands === null || brands.includes(brand);
                        card.hidden = !show;
                        if (show) {
                            visible += 1;
                        }
                    });

                    if (noMatch) {
                        noMatch.hidden = visible > 0;
                    }
                }

                function sortCards() {
                    const mode = sortSelect?.value || 'newest';
                    const sorted = cards.slice().sort(function (a, b) {
                        const idA = Number(a.getAttribute('data-product-id') || 0);
                        const idB = Number(b.getAttribute('data-product-id') || 0);
                        const priceA = Number(a.getAttribute('data-price') || 0);
                        const priceB = Number(b.getAttribute('data-price') || 0);
                        const nameA = a.getAttribute('data-name') || '';
                        const nameB = b.getAttribute('data-name') || '';

                        if (mode === 'price-asc') {
                            return priceA - priceB || idB - idA;
                        }
                        if (mode === 'price-desc') {
                            return priceB - priceA || idB - idA;
                        }
                        if (mode === 'name') {
                            return nameA.localeCompare(nameB) || idB - idA;
                        }

                        return idB - idA;
                    });

                    sorted.forEach(function (card) {
                        grid.appendChild(card);
                    });
                }

                brandAll?.addEventListener('change', function () {
                    if (brandAll.checked) {
                        brandInputs.forEach(function (input) {
                            input.checked = false;
                        });
                    }
                    applyFilters();
                });

                brandInputs.forEach(function (input) {
                    input.addEventListener('change', function () {
                        if (input.checked && brandAll) {
                            brandAll.checked = false;
                        }
                        const anyChecked = Array.from(brandInputs).some(function (el) {
                            return el.checked;
                        });
                        if (!anyChecked && brandAll) {
                            brandAll.checked = true;
                        }
                        applyFilters();
                    });
                });

                sortSelect?.addEventListener('change', sortCards);

                sortCards();
                applyFilters();
            }

            document.addEventListener('DOMContentLoaded', initLpReleases);
            document.addEventListener('turbo:load', initLpReleases);
            document.addEventListener('turbo:render', initLpReleases);

            document.addEventListener('turbo:before-cache', function () {
                const root = document.querySelector('[data-lp-releases]');
                if (root) {
                    delete root.dataset.lpReleasesInit;
                }
            });

            if (document.readyState !== 'loading') {
                initLpReleases();
            }
        })();
    </script>
{% endblock %}
