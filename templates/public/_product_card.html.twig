{# Same card as Releases page. Expects: product (Products entity), brandLabel (optional) #}
{% set name = product.name|default('')|trim %}
{% set brand = brandLabel ?? null %}
{% if brand is null and name %}
    {% set nameParts = name|split(' ') %}
    {% set brand = nameParts|length > 1 ? nameParts[0]|upper : null %}
{% endif %}
{% set displayName = name|upper %}
{% set primary = product.primaryImage %}

<article class="lp-releases-card">
    <div class="lp-releases-card__inner">
        <button type="button" class="lp-releases-card__wishlist" aria-label="Save {{ name }} to wishlist" onclick="event.preventDefault(); event.stopPropagation();">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 20.25l-1.45-1.32C5.4 14.36 2 11.28 2 7.5 2 5 4 3 6.5 3c1.74 0 3.41 1.01 4.22 2.44C11.09 4.01 12.76 3 14.5 3 17 3 19 5 19 7.5c0 3.78-3.4 6.86-8.55 11.43L12 20.25z" stroke="currentColor" stroke-width="1.6"/>
            </svg>
        </button>
        <a href="{{ path('public_product_show', { id: product.id }) }}" class="lp-releases-card__link" data-turbo-frame="_top">
            <div class="lp-releases-card__media">
                {% if primary %}
                    {% if primary starts with 'http' %}
                        <img src="{{ primary }}" alt="{{ name }}" loading="lazy" decoding="async">
                    {% else %}
                        <img src="{{ asset(primary) }}" alt="{{ name }}" loading="lazy" decoding="async">
                    {% endif %}
                {% else %}
                    <img src="{{ asset('img/shoes-r-us-logo.png') }}" alt="{{ name }}" loading="lazy" decoding="async">
                {% endif %}
            </div>
            <div class="lp-releases-card__body">
                {% if brand %}
                    <p class="lp-releases-card__brand">{{ brand }}</p>
                {% endif %}
                <p class="lp-releases-card__name">{{ displayName }}</p>
                <p class="lp-releases-card__price">
                    {{ product.price ? '₱' ~ product.price|number_format(0, '.', ',') : '—' }}
                </p>
            </div>
        </a>
    </div>
</article>
