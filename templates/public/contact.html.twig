{% extends 'public/_layout.html.twig' %}

{% block title %}Contact Us • Shoes R' Us{% endblock %}

{% block body_class %}lp-home{% endblock %}

{% block public_page_body %}

  <main class="lp-page lp-page--contact" id="contact-main">
    <div class="lp-contact-shell">
      <header class="lp-contact-intro">
        <p class="lp-contact-outreach__eyebrow">Reach out anytime</p>
        <h1 class="lp-contact-page__title">Contact Us</h1>
      </header>

      <div class="lp-contact-outreach__grid">
        <article class="lp-contact-outreach-card">
          <div class="lp-contact-outreach-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
              <path d="M12 1a9 9 0 00-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7a9 9 0 00-9-9z"/>
            </svg>
          </div>
          <h2 class="lp-contact-outreach-card__title">Customer support</h2>
          <p class="lp-contact-outreach-card__text">Find answers and get help with your account or orders.</p>
          <a class="lp-contact-outreach-card__link" href="{{ path('app_landingpage_legacy') }}">Visit help center</a>
        </article>

        <article class="lp-contact-outreach-card">
          <div class="lp-contact-outreach-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
              <path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/>
            </svg>
          </div>
          <h2 class="lp-contact-outreach-card__title">Retail &amp; partnerships</h2>
          <p class="lp-contact-outreach-card__text">For wholesale, stockists, and larger collaboration opportunities.</p>
          <a class="lp-contact-outreach-card__link" href="mailto:business@shoesrus.com">Contact us</a>
        </article>

        <article class="lp-contact-outreach-card">
          <div class="lp-contact-outreach-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
              <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
            </svg>
          </div>
          <h2 class="lp-contact-outreach-card__title">Feedback &amp; reports</h2>
          <p class="lp-contact-outreach-card__text">For concerns or requests—please submit the form linked below.</p>
          <a class="lp-contact-outreach-card__link" href="https://forms.gle/Yr85iCgvAPReueyT8" target="_blank" rel="noopener noreferrer">Open Google Form</a>
        </article>
      </div>

      <section class="lp-contact-social" aria-label="Follow us">
        <p class="lp-contact-social__label">Follow us</p>
        <div class="lp-contact-social__links">
          <a class="lp-contact-social__link" href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07C2 17.1 5.66 21.26 10.44 22v-7.03H7.9v-2.9h2.54V9.84c0-2.52 1.49-3.92 3.78-3.92 1.1 0 2.25.2 2.25.2v2.47h-1.27c-1.25 0-1.64.78-1.64 1.58v1.9h2.79l-.45 2.9h-2.34V22C18.34 21.26 22 17.1 22 12.07z"/>
            </svg>
          </a>
          <a class="lp-contact-social__link" href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.9A3.85 3.85 0 0 0 3.9 7.75v8.5a3.85 3.85 0 0 0 3.85 3.85h8.5a3.85 3.85 0 0 0 3.85-3.85v-8.5a3.85 3.85 0 0 0-3.85-3.85h-8.5zm8.98 1.44a1.17 1.17 0 1 1 0 2.34 1.17 1.17 0 0 1 0-2.34zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 1.9A3.1 3.1 0 1 0 12 15.1 3.1 3.1 0 0 0 12 8.9z"/>
            </svg>
          </a>
          <a class="lp-contact-social__link" href="https://tiktok.com" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M14.5 3h2.22c.26 1.6 1.52 2.87 3.13 3.12V8.4a6.22 6.22 0 0 1-3.04-.8v6.14A5.74 5.74 0 1 1 11.07 8v2.36a3.37 3.37 0 1 0 3.43 3.37V3z"/>
            </svg>
          </a>
        </div>
      </section>
    </div>
  </main>

{% endblock %}
