{% extends 'dashboard/index.html.twig' %}

{% block title %}{{ order.displayOrderNumber }} • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[900px] p-4 sm:p-6">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-2xl font-semibold">{{ order.displayOrderNumber }}</h1>
      <div class="flex items-center gap-2">
        <a href="{{ path('admin_orders_index') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all">Back</a>
        <a href="{{ path('admin_orders_edit', {id: order.id}) }}" class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-md transition-all hover:shadow-lg">Edit</a>
      </div>
    </div>

    {% for message in app.flashes('success') %}
      <div class="rounded-xl bg-green-50 border border-green-200 p-3 text-green-800 mb-3">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
      <div class="rounded-xl bg-red-50 border border-red-200 p-3 text-red-800 mb-3">{{ message }}</div>
    {% endfor %}

    <div class="rounded-xl border border-border bg-white shadow-card p-4 space-y-4">
      <form method="post" action="{{ path('admin_orders_update_status', {id: order.id}) }}" class="flex flex-wrap items-end gap-3 rounded-lg border border-border bg-[#F9FAFB] p-3">
        <input type="hidden" name="_token" value="{{ csrf_token('order_status' ~ order.id) }}">
        <label class="flex flex-col gap-1 text-sm font-semibold text-text">
          Update status
          <select name="status" class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-brand focus:outline-none">
            {% for s in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'] %}
              <option value="{{ s }}" {{ order.orderStatus == s ? 'selected' : '' }}>{{ s }}</option>
            {% endfor %}
          </select>
        </label>
        <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-md hover:shadow-lg">Save status</button>
      </form>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div><span class="text-xs text-textMuted">Reference</span><div class="font-mono text-sm">{{ order.displayOrderNumber }}</div></div>
        <div><span class="text-xs text-textMuted">Customer</span><div class="font-medium">{{ order.customerName }}</div></div>
        <div><span class="text-xs text-textMuted">Email</span><div>{{ order.email }}</div></div>
        <div><span class="text-xs text-textMuted">Payment</span><div>{{ order.paymentMethod }}</div></div>
        <div><span class="text-xs text-textMuted">Status</span><div class="font-medium">{{ order.orderStatus }}</div></div>
        <div><span class="text-xs text-textMuted">Quantity</span><div>{{ order.quantity }}</div></div>
        <div><span class="text-xs text-textMuted">Total</span><div>₱{{ order.totalPrice }}</div></div>
        <div><span class="text-xs text-textMuted">Date</span><div>{{ order.dateCreated ? order.dateCreated|date('Y-m-d H:i') : '—' }}</div></div>
        <div><span class="text-xs text-textMuted">Tracking #</span><div>{{ order.trackingNumber ?: '—' }}</div></div>
      </div>

      <div>
        <span class="text-xs text-textMuted">Remarks</span>
        <div class="whitespace-pre-wrap">{{ order.remarks ?: '—' }}</div>
      </div>

      <div>
        <span class="text-xs text-textMuted">Products</span>
        <ul class="list-disc pl-5">
          {% for p in order.products %}
            <li>{{ p.name }} — {{ p.color }} / {{ p.size }} — ₱{{ p.price }}</li>
          {% else %}
            <li class="text-textMuted">No products attached</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</div>
{% endblock %}



