{% extends 'dashboard/index.html.twig' %}

{% block title %}Orders • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[1200px] p-4 sm:p-6">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-2xl font-semibold">Orders</h1>
      <div class="flex items-center gap-2">
        <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all" title="Return to dashboard" aria-label="Return to dashboard">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline><path d="M20 12H10"></path></svg>
          <span class="sr-only">Dashboard</span>
        </a>
        <a href="{{ path('admin_orders_new') }}" class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-md transition-all hover:shadow-lg">
          <i data-lucide="plus" class="h-5 w-5"></i>
          New Order
        </a>
      </div>
    </div>

    {% for message in app.flashes('success') %}
      <div class="rounded-xl bg-green-50 border border-green-200 p-3 text-green-800 mb-3">{{ message }}</div>
    {% endfor %}

    <div class="rounded-xl border border-border bg-white shadow-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wider text-textMuted">
              <th class="border-b border-border px-4 py-3">Order #</th>
              <th class="border-b border-border px-4 py-3">Customer</th>
              <th class="border-b border-border px-4 py-3">Email</th>
              <th class="border-b border-border px-4 py-3">Status</th>
              <th class="border-b border-border px-4 py-3">Total</th>
              <th class="border-b border-border px-4 py-3">Date</th>
              <th class="border-b border-border px-4 py-3">Actions</th>
            </tr>
          </thead>
          <tbody
            id="orders-live-body"
            data-live-url="{{ path('admin_orders_live') }}"
            data-latest-id="{{ orders|length > 0 ? orders[0].id : 0 }}"
          >
            {% include 'orders/_rows.html.twig' with { orders: orders } %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tbody = document.getElementById('orders-live-body');
    if (!tbody) return;

    const liveUrl = tbody.dataset.liveUrl;
    if (!liveUrl) return;

    let latestId = Number.parseInt(tbody.dataset.latestId || '0', 10) || 0;

    const refreshRows = async () => {
      try {
        const response = await fetch(`${liveUrl}?latestId=${latestId}`, {
          method: 'GET',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
        });
        if (!response.ok) return;
        const data = await response.json();
        if (!data || !data.hasChanges) return;
        if (typeof data.rowsHtml === 'string') {
          tbody.innerHTML = data.rowsHtml;
        }
        latestId = Number.parseInt(String(data.latestId ?? latestId), 10) || latestId;
        tbody.dataset.latestId = String(latestId);
        window.lucide?.createIcons();
      } catch (error) {
        // Silent fail: keeps page usable if network hiccups happen.
      }
    };

    setInterval(refreshRows, 5000);
  });
</script>
{% endblock %}


