<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="{{ asset('img/shoes-r-us-logo.png') }}">
        <style>
            body { font-family: sans-serif; }
            h1, h2, h3, h4, h5, h6 { font-family: "Sora", sans-serif; font-weight: 700; }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% block flashes %}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div style="margin:12px auto;max-width:720px;padding:12px 16px;border-radius:8px;border:1px solid {{ label == 'success' ? '#cfc' : '#fcc' }};background: {{ label == 'success' ? '#efe' : '#fee' }};color: {{ label == 'success' ? '#363' : '#c33' }};">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        {% endblock %}

        {% block body %}{% endblock %}
    </body>
</html>
