{% extends 'dashboard/index.html.twig' %}

{% block title %}Transactions • Admin{% endblock %}

{% block dashboard_content %}
{% if mode == 'chooser' %}
<div class="mx-auto max-w-4xl space-y-10 p-4 sm:p-10">
  <div class="text-center space-y-2">
    <p class="text-xs font-semibold uppercase tracking-[4px] text-textMuted">Transactions Hub</p>
    <h1 class="text-3xl font-semibold text-text">Pick a transaction type</h1>
    <p class="text-sm text-textMuted">Choose what you want to review. You can always return here to switch views.</p>
  </div>
  <div class="grid gap-6 md:grid-cols-2">
    <a href="{{ path('admin_transactions_index', {type: 'sales'}) }}" class="group rounded-2xl border border-border bg-white/80 p-6 shadow-card transition-all hover:-translate-y-1 hover:border-brand hover:shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Retail</p>
          <h2 class="mt-1 text-2xl font-semibold text-text">Sales transactions</h2>
        </div>
        <span class="rounded-full bg-brand/10 p-3 text-brand">
          <i data-lucide="credit-card" class="h-6 w-6"></i>
        </span>
      </div>
      <p class="mt-4 text-sm text-textMuted">Track paid orders, amounts collected, payment mix, and fulfillment health in one workspace.</p>
      <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand">
        Enter workspace
        <i data-lucide="arrow-right" class="h-4 w-4 transition group-hover:translate-x-1"></i>
      </div>
    </a>
    <a href="{{ path('admin_transactions_index', {type: 'services'}) }}" class="group rounded-2xl border border-border bg-white/80 p-6 shadow-card transition-all hover:-translate-y-1 hover:border-brand hover:shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Services Lab</p>
          <h2 class="mt-1 text-2xl font-semibold text-text">Services transactions</h2>
        </div>
        <span class="rounded-full bg-brand/10 p-3 text-brand">
          <i data-lucide="sparkles" class="h-6 w-6"></i>
        </span>
      </div>
      <p class="mt-4 text-sm text-textMuted">Review service tickets, their stages, and lab throughput before handing pairs back to customers.</p>
      <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand">
        Open service desk
        <i data-lucide="arrow-right" class="h-4 w-4 transition group-hover:translate-x-1"></i>
      </div>
    </a>
  </div>
</div>
{% elseif mode == 'services' %}
<div class="mx-auto max-w-[1200px] space-y-6 p-4 sm:p-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Services Lab</p>
      <h1 class="text-2xl font-semibold text-text">Service transactions</h1>
      <p class="text-sm text-textMuted">Spot bottlenecks in the lab and jump straight to a job that needs an update.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ path('admin_transactions_index') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:border-brand hover:text-brand transition-all">
        <i data-lucide="grid" class="h-4 w-4"></i>
        Choose type
      </a>
      <a href="{{ path('admin_transactions_index', {type: 'sales'}) }}" class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-card hover:shadow-lg transition-all">
        <i data-lucide="credit-card" class="h-4 w-4 text-white"></i>
        Sales transactions
      </a>
    </div>
  </div>

  <form method="get" action="{{ path('admin_transactions_index') }}" class="rounded-2xl border border-border bg-white p-4 shadow-card">
    <input type="hidden" name="type" value="services">
    <div class="flex flex-wrap gap-4">
      <label class="flex flex-col gap-1 text-sm font-semibold text-text">
        Rows
        {% set limits = {'25':25,'50':50,'100':100,'200':200,'0':'All'} %}
        <select name="limit" class="rounded-xl border border-border px-3 py-2 text-sm focus:border-brand focus:outline-none">
          {% for key,value in limits %}
            <option value="{{ key }}" {{ (limit is null and key == '0') or (limit is not null and value == limit) ? 'selected' : '' }}>{{ value }}</option>
          {% endfor %}
        </select>
      </label>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <button class="rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-card hover:shadow-lg transition-all" type="submit">Apply</button>
      <a href="{{ path('admin_transactions_index', {type: 'services'}) }}" class="rounded-xl border border-border px-4 py-2 text-sm font-medium text-text hover:border-brand hover:text-brand transition-all">Reset</a>
    </div>
  </form>

  <section class="grid gap-4 md:grid-cols-3">
    <div class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Jobs in scope</p>
      <p class="mt-2 text-2xl font-bold text-text">{{ serviceSummary.total }}</p>
      <p class="text-xs text-textMuted mt-1">All service transactions on record</p>
    </div>
    <div class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Status buckets</p>
      <p class="mt-2 text-2xl font-bold text-text">{{ serviceSummary.status|length }}</p>
      <p class="text-xs text-textMuted mt-1">Tracked in this filter</p>
    </div>
    <div class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Latest update</p>
      {% set latest = serviceFeed|first %}
      <p class="mt-2 text-2xl font-bold text-text">{{ latest and latest.updatedAt ? latest.updatedAt|date('M d, Y • H:i') : '—' }}</p>
      <p class="text-xs text-textMuted mt-1">Based on most recently touched ticket</p>
    </div>
  </section>

  <section class="rounded-2xl border border-border bg-white p-4 shadow-card">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold uppercase tracking-[3px] text-textMuted">Status mix</h2>
      <span class="text-xs text-textMuted">{{ serviceSummary.status|length }} statuses</span>
    </div>
    <div class="mt-4 space-y-3">
      {% for bucket in serviceSummary.status %}
        <div>
          <div class="flex justify-between text-sm font-medium text-text">
            <span>{{ bucket.label }}</span>
            <span>{{ bucket.count }}</span>
          </div>
          <div class="mt-1 h-2 rounded-full bg-card">
            {% set percent = serviceSummary.total > 0 ? (bucket.count / serviceSummary.total * 100) : 0 %}
            <div class="h-2 rounded-full bg-brand" style="width: {{ percent }}%;"></div>
          </div>
        </div>
      {% else %}
        <p class="text-sm text-textMuted">No service transactions recorded yet.</p>
      {% endfor %}
    </div>
  </section>

  <section class="rounded-2xl border border-border bg-white shadow-card">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border px-4 py-3">
      <div>
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Service activity</p>
        <h2 class="text-lg font-semibold text-text">Latest jobs</h2>
      </div>
      <p class="text-xs text-textMuted">
        {% if serviceSummary.total == (serviceFeed|length) %}
          Showing {{ serviceFeed|length }} records
        {% else %}
          Showing {{ serviceFeed|length }} of {{ serviceSummary.total }}
        {% endif %}
      </p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full border-separate border-spacing-0 text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wider text-textMuted">
            <th class="border-b border-border px-4 py-3">ID</th>
            <th class="border-b border-border px-4 py-3">Shoe</th>
            <th class="border-b border-border px-4 py-3">Service</th>
            <th class="border-b border-border px-4 py-3">Status</th>
            <th class="border-b border-border px-4 py-3">Updated</th>
            <th class="border-b border-border px-4 py-3">Note</th>
            <th class="border-b border-border px-4 py-3 text-right">Action</th>
          </tr>
        </thead>
        <tbody>
          {% for job in serviceFeed %}
            <tr>
              <td class="border-b border-border px-4 py-3 font-semibold text-text">#{{ job.id }}</td>
              <td class="border-b border-border px-4 py-3">
                <div class="font-medium">{{ job.shoe }}</div>
                <p class="text-xs text-textMuted">Created {{ job.createdAt ? job.createdAt|date('Y-m-d H:i') : '—' }}</p>
              </td>
              <td class="border-b border-border px-4 py-3">{{ job.type }}</td>
              <td class="border-b border-border px-4 py-3">
                <span class="inline-flex items-center rounded-full border px-2 py-1 text-xs font-semibold" data-status="{{ job.status }}">
                  {{ job.status }}
                </span>
              </td>
              <td class="border-b border-border px-4 py-3 text-sm text-textMuted">
                {{ job.updatedAt ? job.updatedAt|date('Y-m-d H:i') : '—' }}
              </td>
              <td class="border-b border-border px-4 py-3 text-sm text-textMuted">
                {% if job.note %}
                  {{ job.note|length > 60 ? job.note|slice(0, 60) ~ '…' : job.note }}
                {% else %}
                  —
                {% endif %}
              </td>
              <td class="border-b border-border px-4 py-3 text-right">
                <a href="{{ path('admin_service_edit', {id: job.id}) }}" class="inline-flex items-center gap-1 text-sm font-semibold text-brand hover:underline">
                  Update
                  <i data-lucide="external-link" class="h-4 w-4"></i>
                </a>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="7" class="px-4 py-10 text-center text-sm text-textMuted">No service transactions yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</div>
{% else %}
<div class="mx-auto max-w-[1200px] space-y-6 p-4 sm:p-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Finance</p>
      <h1 class="text-2xl font-semibold text-text">Sales transactions</h1>
      <p class="text-sm text-textMuted">Monitor recent payment activity and quickly drill down into individual orders.</p>
      <div class="mt-3 flex flex-wrap gap-2 text-xs text-textMuted">
        <a href="{{ path('admin_transactions_index') }}" class="inline-flex items-center gap-1 rounded-full border border-border px-3 py-1 font-medium hover:border-brand hover:text-brand transition">
          <i data-lucide="grid" class="h-3 w-3"></i>
          Choose type
        </a>
        <a href="{{ path('admin_transactions_index', {type: 'services'}) }}" class="inline-flex items-center gap-1 rounded-full border border-border px-3 py-1 font-medium hover:border-brand hover:text-brand transition">
          <i data-lucide="sparkles" class="h-3 w-3"></i>
          Service view
        </a>
      </div>
    </div>
    <div class="flex gap-2">
      <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:border-brand hover:text-brand transition-all" title="Back to dashboard">
        <i data-lucide="arrow-left" class="h-4 w-4"></i>
        Dashboard
      </a>
      <a href="{{ path('admin_orders_index') }}" class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-card hover:shadow-lg transition-all" title="View orders table">
        <i data-lucide="package" class="h-4 w-4 text-white"></i>
        Orders
      </a>
    </div>
  </div>

  <form method="get" action="{{ path('admin_transactions_index') }}" class="rounded-2xl border border-border bg-white p-4 shadow-card">
    <input type="hidden" name="type" value="sales">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm font-semibold text-text">
        Search
        <div class="relative">
          <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400"></i>
          <input type="search" name="search" value="{{ searchTerm }}" placeholder="Customer, email, tracking, ID…" class="w-full rounded-xl border border-border pl-9 pr-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20" />
        </div>
      </label>
      <label class="flex flex-col gap-1 text-sm font-semibold text-text">
        Status
        <span class="text-xs font-normal text-textMuted">(filter only — does not change customer orders)</span>
        <select name="status" class="rounded-xl border border-border px-3 py-2 text-sm focus:border-brand focus:outline-none">
          {% set statuses = ['All','Pending','Processing','Shipped','Delivered','Cancelled'] %}
          {% for s in statuses %}
            <option value="{{ s }}" {{ s == statusFilter ? 'selected' : '' }}>{{ s }}</option>
          {% endfor %}
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm font-semibold text-text">
        Payment Method
        <select name="payment" class="rounded-xl border border-border px-3 py-2 text-sm focus:border-brand focus:outline-none">
          {% set payments = ['All','COD','GCash','Bank Transfer','Card'] %}
          {% for p in payments %}
            <option value="{{ p }}" {{ p == paymentFilter ? 'selected' : '' }}>{{ p }}</option>
          {% endfor %}
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm font-semibold text-text">
        Rows
        {% set limits = {'25':25,'50':50,'100':100,'200':200,'0':'All'} %}
        <select name="limit" class="rounded-xl border border-border px-3 py-2 text-sm focus:border-brand focus:outline-none">
          {% for key,value in limits %}
            <option value="{{ key }}" {{ (limit is null and key == '0') or (limit is not null and value == limit) ? 'selected' : '' }}>{{ value }}</option>
          {% endfor %}
        </select>
      </label>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <button class="rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-card hover:shadow-lg transition-all" type="submit">Apply filters</button>
      <a href="{{ path('admin_transactions_index', {type: 'sales'}) }}" class="rounded-xl border border-border px-4 py-2 text-sm font-medium text-text hover:border-brand hover:text-brand transition-all">Reset</a>
    </div>
  </form>

  <section class="grid gap-4 md:grid-cols-3">
    <div class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Total Volume</p>
      <p class="mt-2 text-2xl font-bold text-text">₱{{ insights.totals.volume|number_format(2, '.', ',') }}</p>
      <p class="text-xs text-textMuted mt-1">Across {{ insights.totals.count }} transactions</p>
    </div>
    <div class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Average Order Value</p>
      <p class="mt-2 text-2xl font-bold text-text">₱{{ insights.totals.average|number_format(2, '.', ',') }}</p>
      <p class="text-xs text-textMuted mt-1">Filtered dataset</p>
    </div>
    <div class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <p class="text-xs font-semibold uppercase tracking-[3px] text-textMuted">Showing</p>
      <p class="mt-2 text-2xl font-bold text-text">
        {% if transactions|length == insights.totals.count %}
          {{ transactions|length }} records
        {% else %}
          {{ transactions|length }} of {{ insights.totals.count }}
        {% endif %}
      </p>
      <p class="text-xs text-textMuted mt-1">Most recent first</p>
    </div>
  </section>

  <div class="grid gap-4 md:grid-cols-2">
    <section class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-[3px] text-textMuted">Status mix</h2>
        <span class="text-xs text-textMuted">{{ insights.status|length }} statuses</span>
      </div>
      <div class="mt-4 space-y-3">
        {% for bucket in insights.status %}
          <div>
            <div class="flex justify-between text-sm font-medium text-text">
              <span>{{ bucket.label }}</span>
              <span>{{ bucket.count }}</span>
            </div>
            <div class="mt-1 h-2 rounded-full bg-card">
              {% set percent = insights.totals.count > 0 ? (bucket.count / insights.totals.count * 100) : 0 %}
              <div class="h-2 rounded-full bg-brand" style="width: {{ percent }}%;"></div>
            </div>
          </div>
        {% else %}
          <p class="text-sm text-textMuted">No transactions yet.</p>
        {% endfor %}
      </div>
    </section>

    <section class="rounded-2xl border border-border bg-white p-4 shadow-card">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-[3px] text-textMuted">Payment mix</h2>
        <span class="text-xs text-textMuted">{{ insights.payment|length }} methods</span>
      </div>
      <div class="mt-4 space-y-3">
        {% for bucket in insights.payment %}
          <div class="flex flex-col gap-1">
            <div class="flex justify-between text-sm font-medium text-text">
              <span>{{ bucket.label }}</span>
              <span>₱{{ bucket.volume|number_format(2, '.', ',') }}</span>
            </div>
            <p class="text-xs text-textMuted">{{ bucket.count }} transactions</p>
          </div>
        {% else %}
          <p class="text-sm text-textMuted">No payment data yet.</p>
        {% endfor %}
      </div>
    </section>
  </div>

  <section class="rounded-2xl border border-border bg-white shadow-card">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border px-4 py-3">
      <div>
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Transactions list</p>
        <h2 class="text-lg font-semibold text-text">Recent activity</h2>
      </div>
      <p class="text-xs text-textMuted">Sorted by newest first</p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full border-separate border-spacing-0 text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wider text-textMuted">
            <th class="border-b border-border px-4 py-3">ID</th>
            <th class="border-b border-border px-4 py-3">Customer</th>
            <th class="border-b border-border px-4 py-3">Email</th>
            <th class="border-b border-border px-4 py-3">Payment</th>
            <th class="border-b border-border px-4 py-3">Status</th>
            <th class="border-b border-border px-4 py-3">Total</th>
            <th class="border-b border-border px-4 py-3">Created</th>
            <th class="border-b border-border px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for tx in transactions %}
            <tr>
              <td class="border-b border-border px-4 py-3 font-semibold text-text">#{{ tx.id }}</td>
              <td class="border-b border-border px-4 py-3">
                <div class="font-medium">{{ tx.customerName }}</div>
                <div class="text-xs text-textMuted">Qty: {{ tx.quantity }}</div>
              </td>
              <td class="border-b border-border px-4 py-3">{{ tx.email }}</td>
              <td class="border-b border-border px-4 py-3">{{ tx.paymentMethod }}</td>
              <td class="border-b border-border px-4 py-3">
                <span class="inline-flex items-center rounded-full border px-2 py-1 text-xs font-semibold" data-status="{{ tx.orderStatus }}">
                  {{ tx.orderStatus }}
                </span>
              </td>
              <td class="border-b border-border px-4 py-3 font-semibold">₱{{ tx.totalPrice|number_format(2, '.', ',') }}</td>
              <td class="border-b border-border px-4 py-3 text-sm text-textMuted">
                {{ tx.dateCreated ? tx.dateCreated|date('Y-m-d H:i') : '—' }}
              </td>
              <td class="border-b border-border px-4 py-3 text-right">
                <a href="{{ path('admin_orders_show', {id: tx.id}) }}" class="inline-flex items-center gap-1 text-sm font-semibold text-brand hover:underline">
                  View
                  <i data-lucide="external-link" class="h-4 w-4"></i>
                </a>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="8" class="px-4 py-10 text-center text-sm text-textMuted">No transactions match your filters yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</div>
{% endif %}
{% endblock %}

