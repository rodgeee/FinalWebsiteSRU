<div class="rounded-xl border border-border bg-white shadow-card p-6 space-y-6">
  {% if app.flashes('error') %}
    {% for message in app.flashes('error') %}
      <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700">{{ message }}</div>
    {% endfor %}
  {% endif %}

  {{ form_start(form) }}
    <div class="space-y-6">
      <div>
        <h2 class="text-sm font-semibold text-textMuted uppercase tracking-[3px] mb-2">Existing Product</h2>
        {{ form_row(form.Product) }}
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="md:col-span-2">
          <h2 class="text-sm font-semibold text-textMuted uppercase tracking-[3px] mb-2">New Product Details (optional)</h2>
          <p class="text-xs text-textMuted mb-3">Leave blank if you selected an existing product above. Fill these fields to create or update product information while managing stock.</p>
        </div>
        <div class="flex flex-col">
          {{ form_row(form.productName) }}
        </div>
        <div class="flex flex-col">
          {{ form_row(form.productColor) }}
        </div>
        <div class="flex flex-col">
          {{ form_row(form.productSize) }}
        </div>
        <div class="flex flex-col">
          {{ form_label(form.productPrice) }}
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-textMuted pointer-events-none">₱</span>
            {{ form_widget(form.productPrice, {'attr': form.productPrice.vars.attr }) }}
          </div>
          {{ form_errors(form.productPrice) }}
        </div>
        <div class="md:col-span-2">
          {{ form_row(form.productDescription) }}
        </div>
        {% set resolvedExistingImages = [] %}
        {% for path in existingImages|default([]) %}
          {% set resolvedExistingImages = resolvedExistingImages|merge([path starts with 'http' ? path : asset(path)]) %}
        {% endfor %}
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-2">Product Images</label>
          <div
            class="image-dropzone"
            data-controller="product-images"
            data-product-images-max-files-value="4"
            data-product-images-existing-value='{{ resolvedExistingImages|json_encode|e('html_attr') }}'>
            <div
              class="image-dropzone__area"
              data-product-images-target="dropzone"
              data-action="click->product-images#openFileDialog dragover->product-images#handleDragOver dragleave->product-images#handleDragLeave drop->product-images#handleDrop">
              <div class="image-dropzone__content">
                <p class="text-sm font-semibold text-text">Drag & drop images here</p>
                {# <p class="text-xs text-textMuted">or click to browse files</p> #}
                <p class="text-xs text-textMuted mt-1">PNG, JPG, WEBP • up to 5MB each • max 4 images</p>
              </div>
              {{ form_widget(form.productImages, {
                attr: form.productImages.vars.attr|merge({
                  'data-product-images-target': 'fileInput',
                  'data-action': 'change->product-images#handleFileSelect'
                })
              }) }}
            </div>
            {{ form_errors(form.productImages) }}
            <div class="image-dropzone__previews" data-product-images-target="preview"></div>
            <p class="text-xs text-textMuted mt-2" data-product-images-target="message">
              Uploading new files replaces any previously saved gallery for this product.
            </p>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-textMuted uppercase tracking-[3px] mb-2">Stock Data</h2>
        {{ form_row(form.Quantity) }}
      </div>
    </div>

    <div class="flex items-center gap-3 pt-6">
      <button class="inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-md transition-all hover:shadow-lg">
        <i data-lucide="save" class="h-5 w-5"></i>
        {{ button_label|default('Save') }}
      </button>
      <a href="{{ path('admin_stocks_index') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all">
        Cancel
      </a>
    </div>
  {{ form_end(form) }}
</div>

