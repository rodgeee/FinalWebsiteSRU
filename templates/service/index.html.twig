{% extends 'dashboard/index.html.twig' %}

{% block title %}Shoe Lab • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[1200px] space-y-6">
  <section class="rounded-2xl border border-border bg-white/90 p-6 shadow-card flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
    <div class="space-y-3 max-w-xl">
      <p class="text-xs uppercase tracking-[4px] text-brand">Shoe cleaning & repair lab</p>
      <h1 class="text-3xl font-semibold text-text">Track every pair from intake to pickup.</h1>
      <p class="text-sm text-textMuted">
        Live view of the cleaning benches, repair stations, and finishing booth so you can update customers with confidence.
        Watch progress bars move in real-time and log new jobs without leaving the page.
      </p>
      <div class="flex flex-wrap gap-6 text-sm text-textMuted">
        <div>
          <p class="text-3xl font-semibold text-text">{{ serviceSummary.avgProgress ?? 0 }}%</p>
          <p>Average completion</p>
        </div>
        <div>
          <p class="text-3xl font-semibold text-text">{{ serviceSummary.avgEtaLabel }}</p>
          <p>Average ETA</p>
        </div>
      </div>
    </div>
    <div class="grid w-full gap-4 sm:grid-cols-2 lg:w-auto">
      <article class="rounded-xl border border-border bg-card/60 p-4">
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Active jobs</p>
        <p class="mt-2 text-2xl font-semibold text-text">{{ serviceSummary.active }}</p>
        <p class="text-xs text-textMuted">Across all cleaning & repair bays</p>
      </article>
      <article class="rounded-xl border border-border bg-card/60 p-4">
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Ready for pickup</p>
        <p class="mt-2 text-2xl font-semibold text-text">{{ serviceSummary.ready }}</p>
        <p class="text-xs text-textMuted">Notified customers today</p>
      </article>
      <article class="rounded-xl border border-border bg-card/60 p-4">
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Clean room</p>
        <p class="mt-2 text-2xl font-semibold text-text">{{ serviceSummary.cleaning }}</p>
        <p class="text-xs text-textMuted">Pairs on soak, scrub, or dry</p>
      </article>
      <article class="rounded-xl border border-border bg-card/60 p-4">
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Repair bench</p>
        <p class="mt-2 text-2xl font-semibold text-text">{{ serviceSummary.repair }}</p>
        <p class="text-xs text-textMuted">Stitch, sole, repaint queue</p>
      </article>
    </div>
  </section>

  {% for message in app.flashes('success') %}
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm">{{ message }}</div>
  {% endfor %}

  <section class="grid gap-4 lg:grid-cols-3">
    <article class="lg:col-span-2 rounded-2xl border border-border bg-white shadow-card">
      <div class="flex flex-col gap-1 border-b border-border px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[3px] text-textMuted">LIVE MONITORING</p>
          <h2 class="text-xl font-semibold text-text">Active service queue</h2>
        </div>
        <div class="text-xs font-semibold text-brand">{{ serviceSummary.active }} pairs under service</div>
      </div>
      <div class="divide-y divide-border">
        {% for job in pipelineJobs %}
          <article class="flex flex-col gap-4 px-5 py-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm font-semibold text-text">{{ job.shoe ?: '—' }}</p>
                <p class="text-xs text-textMuted">{{ job.type ?: 'Custom package' }}{% if job.customerEmail %} · {{ job.customerEmail }}{% endif %}{% if job.source == 'mobile' %} · <span class="text-brand">App booking</span>{% endif %}</p>
              </div>
              <div class="flex flex-col items-end gap-2 text-right">
                <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold {{ job.badge }}">{{ job.status }}</span>
                <p class="text-[11px] text-textMuted">Updated {{ job.updatedAgo }}</p>
                <a href="{{ job.editPath }}" class="inline-flex items-center gap-1 rounded-full border border-border px-3 py-1 text-[11px] font-semibold text-text hover:text-brand hover:border-brand transition-all">
                  <i data-lucide="edit-3" class="h-3.5 w-3.5"></i>
                  Update
                </a>
              </div>
            </div>
            {% if job.note %}
              <p class="text-sm text-textMuted">{{ job.note }}</p>
            {% endif %}
            <div class="space-y-1">
              <div class="h-2 w-full rounded-full bg-card">
                <div class="h-2 rounded-full bg-brand transition-all" style="width: {{ job.progress }}%"></div>
              </div>
              <div class="flex items-center justify-between text-[11px] text-textMuted">
                <span>{{ job.phase }}</span>
                <span>{{ job.etaLabel }}</span>
              </div>
            </div>
          </article>
        {% else %}
          <p class="px-5 py-6 text-sm text-textMuted">No active services yet. Log a pair using the form to start tracking.</p>
        {% endfor %}
      </div>
    </article>
    <div class="space-y-4">
      <article class="rounded-2xl border border-border bg-white p-5 shadow-card">
        <div class="mb-4">
          <p class="text-xs uppercase tracking-[3px] text-textMuted">Service intake</p>
          <h2 class="text-lg font-semibold text-text">Log a shoe service</h2>
          <p class="text-xs text-textMuted">Queue a cleaning or repair ticket — timestamps & status are tracked automatically.</p>
        </div>
        {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
          {{ form_errors(form) }}
          <div>
            {{ form_label(form.ShoeName) }}
            {{ form_widget(form.ShoeName) }}
            {{ form_errors(form.ShoeName) }}
          </div>
          <div>
            {{ form_label(form.ServiceType) }}
            {{ form_widget(form.ServiceType) }}
            {{ form_errors(form.ServiceType) }}
          </div>
          <div>
            {{ form_label(form.Status) }}
            {{ form_widget(form.Status) }}
            {{ form_errors(form.Status) }}
          </div>
          <div>
            {{ form_label(form.Note) }}
            {{ form_widget(form.Note) }}
            {{ form_errors(form.Note) }}
          </div>
          <button type="submit" class="w-full rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-card transition hover:shadow-lg">Queue service</button>
        {{ form_end(form) }}
      </article>

      <article class="rounded-2xl border border-border bg-white p-5 shadow-card space-y-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs uppercase tracking-[3px] text-textMuted">Live updates</p>
            <h2 class="text-lg font-semibold text-text">Floor activity</h2>
          </div>
          <button class="text-xs text-brand hover:underline">Refresh</button>
        </div>
        <div class="space-y-3">
          {% for event in liveFeed %}
            <div class="rounded-xl border border-border/70 px-3 py-2">
              <div class="flex items-center justify-between text-sm font-semibold text-text">
                <span>{{ event.shoe }}</span>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold {{ event.badge }}">{{ event.status }}</span>
              </div>
              <p class="text-xs text-textMuted">{{ event.note }}</p>
              <p class="text-[11px] text-textMuted">Updated {{ event.time }}</p>
            </div>
          {% else %}
            <p class="text-sm text-textMuted">No activity yet — log a service to begin tracking.</p>
          {% endfor %}
        </div>
      </article>

      <article class="rounded-2xl border border-border bg-white p-5 shadow-card space-y-3">
        <p class="text-xs uppercase tracking-[3px] text-textMuted">Quick stats</p>
        <h2 class="text-lg font-semibold text-text">Queue snapshot</h2>
        <div class="space-y-3">
          {% for milestone in labMilestones %}
            <div class="flex items-center gap-3 rounded-xl border border-border/70 px-3 py-2">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-card text-brand">
                <i data-lucide="{{ milestone.icon }}" class="h-5 w-5"></i>
              </div>
              <div class="flex-1">
                <p class="text-sm font-semibold text-text">{{ milestone.title }}</p>
                <p class="text-xs text-textMuted">{{ milestone.detail }}</p>
              </div>
              <span class="text-[11px] font-semibold uppercase tracking-wider text-brand">{{ milestone.status }}</span>
            </div>
          {% endfor %}
        </div>
      </article>
    </div>
  </section>
</div>
{% endblock %}

