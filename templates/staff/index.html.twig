{% extends 'dashboard/index.html.twig' %}

{% block title %}User Management • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[1200px] space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs uppercase tracking-[3px] text-textMuted">Team</p>
      <h1 class="text-2xl font-semibold">User Management</h1>
      <p class="text-sm text-textMuted">Create, edit, or disable user accounts.</p>
    </div>
    <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all" title="Return to dashboard">
      <i data-lucide="layout-dashboard" class="h-5 w-5"></i>
      Dashboard
    </a>
  </div>

  {% for message in app.flashes('success') %}
    <div class="rounded-xl bg-green-50 border border-green-200 p-3 text-green-800">{{ message }}</div>
  {% endfor %}

  <div class="grid gap-4 lg:grid-cols-[1.4fr_1fr]">
    <div class="rounded-xl border border-border bg-white shadow-card overflow-hidden">
      <div class="flex items-center justify-between border-b border-border px-4 py-3">
        <div>
          <h2 class="text-lg font-semibold">Staff accounts</h2>
          <p class="text-xs text-textMuted">{{ staff|length }} account{{ staff|length == 1 ? '' : 's' }}</p>
        </div>
        <div class="text-xs text-textMuted">Active: {{ activeStaff }} / {{ staff|length }}</div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wider text-textMuted">
              <th class="border-b border-border px-4 py-3">Name</th>
              <th class="border-b border-border px-4 py-3">Email</th>
              <th class="border-b border-border px-4 py-3">Role</th>
              <th class="border-b border-border px-4 py-3">Status</th>
              <th class="border-b border-border px-4 py-3">Created</th>
              <th class="border-b border-border px-4 py-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for s in staff %}
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="border-b border-border px-4 py-3 font-medium">{{ s.fullName }}</td>
                <td class="border-b border-border px-4 py-3 text-textMuted">{{ s.email }}</td>
                <td class="border-b border-border px-4 py-3">
                  {{ s.roles ? s.roles|join(', ') : 'ROLE_STAFF' }}
                </td>
                <td class="border-b border-border px-4 py-3">
                  {% set status = s.status ?? (s.isActive ? 'active' : 'disabled') %}
                  {% if status == 'active' %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2 py-1 text-[11px] font-semibold text-green-800">Active</span>
                  {% elseif status == 'archived' %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-gray-200 px-2 py-1 text-[11px] font-semibold text-gray-700">Archived</span>
                  {% else %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2 py-1 text-[11px] font-semibold text-red-800">Disabled</span>
                  {% endif %}
                </td>
                <td class="border-b border-border px-4 py-3 text-textMuted whitespace-nowrap">
                  {{ s.createdAt ? s.createdAt|date('Y-m-d') : '—' }}
                </td>
                <td class="border-b border-border px-4 py-3">
                  <div class="flex items-center gap-2">
                    <a href="{{ path('admin_staff_edit', {id: s.id}) }}" class="inline-flex min-w-[90px] justify-center items-center gap-1 rounded-lg border border-border px-3 py-2 text-xs font-semibold text-gray-700 hover:text-brand hover:border-brand transition">
                    <i data-lucide="pencil" class="h-4 w-4"></i>
                    Edit
                    </a>
                    <form method="post" action="{{ path('admin_staff_delete', {id: s.id}) }}" class="inline" onsubmit="return confirm('Delete this staff account?');">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ s.id) }}">
                      <button type="submit" class="inline-flex min-w-[90px] justify-center items-center gap-1 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-700 hover:bg-red-100 transition">
                        <i data-lucide="trash-2" class="h-4 w-4"></i>
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="6" class="border-b border-border px-4 py-6 text-center text-textMuted">No staff accounts yet.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    <div class="space-y-4">
      <div class="rounded-xl border border-border bg-white shadow-card p-4 space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold">Create account</h2>
          <span class="text-xs text-textMuted">Admins: {{ stats.admins ?? 0 }}</span>
        </div>
        {{ form_start(form, { action: path('admin_staff_new'), method: 'POST' }) }}
          <div class="space-y-3">
            <div>
              {{ form_label(form.fullName) }}
              {{ form_widget(form.fullName, { attr: { class: 'mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand' } }) }}
              {{ form_errors(form.fullName) }}
            </div>
            <div>
              {{ form_label(form.email) }}
              {{ form_widget(form.email, { attr: { class: 'mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand' } }) }}
              {{ form_errors(form.email) }}
            </div>
            <div>
              {{ form_label(form.roleChoice) }}
              {{ form_widget(form.roleChoice, { attr: { class: 'mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand' } }) }}
              <p class="text-[11px] text-textMuted mt-1">Choose Admin for full access or Staff for limited access.</p>
              {{ form_errors(form.roleChoice) }}
            </div>
            <div>
              {{ form_label(form.statusChoice) }}
              {{ form_widget(form.statusChoice, { attr: { class: 'mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand' } }) }}
              <p class="text-[11px] text-textMuted mt-1">Choose account state: active, disabled, or archived.</p>
              {{ form_errors(form.statusChoice) }}
            </div>
            <div>
              {{ form_label(form.plainPassword.first) }}
              <div class="relative">
                {{ form_widget(form.plainPassword.first, { attr: { class: 'mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 pr-12 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand', 'data-password-input': form.plainPassword.first.vars.id } }) }}
                <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 h-9 w-9 inline-flex items-center justify-center rounded-lg text-gray-600 hover:text-brand bg-transparent" aria-label="Show password" data-toggle-password="{{ form.plainPassword.first.vars.id }}" onclick="togglePassword('{{ form.plainPassword.first.vars.id }}', this)">
                  <svg class="h-5 w-5 icon-eye" style="display: inline;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="h-5 w-5 icon-eye-off" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M3 3l18 18M10.58 10.58a3 3 0 104.24 4.24"/>
                    <path d="M9.88 9.88C9.34 10.3 9 10.88 9 12a3 3 0 003 3c1.12 0 1.7-.34 2.12-.88M7.5 7.5C5.06 8.57 3 12 3 12s4 7 9 7c1.47 0 2.79-.37 3.96-1.02M13 5.06C12.67 5.02 12.34 5 12 5 7 5 3 12 3 12c.7 1.25 1.5 2.36 2.35 3.3"/>
                  </svg>
                </button>
              </div>
              {{ form_errors(form.plainPassword.first) }}
            </div>
            <div>
              {{ form_label(form.plainPassword.second) }}
              <div class="relative">
                {{ form_widget(form.plainPassword.second, { attr: { class: 'mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 pr-12 text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand', 'data-password-input': form.plainPassword.second.vars.id } }) }}
                <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 h-9 w-9 inline-flex items-center justify-center rounded-lg text-gray-600 hover:text-brand bg-transparent" aria-label="Show password" data-toggle-password="{{ form.plainPassword.second.vars.id }}" onclick="togglePassword('{{ form.plainPassword.second.vars.id }}', this)">
                  <svg class="h-5 w-5 icon-eye" style="display: inline;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="h-5 w-5 icon-eye-off" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M3 3l18 18M10.58 10.58a3 3 0 104.24 4.24"/>
                    <path d="M9.88 9.88C9.34 10.3 9 10.88 9 12a3 3 0 003 3c1.12 0 1.7-.34 2.12-.88M7.5 7.5C5.06 8.57 3 12 3 12s4 7 9 7c1.47 0 2.79-.37 3.96-1.02M13 5.06C12.67 5.02 12.34 5 12 5 7 5 3 12 3 12c.7 1.25 1.5 2.36 2.35 3.3"/>
                  </svg>
                </button>
              </div>
              {{ form_errors(form.plainPassword.second) }}
              <p class="text-[11px] text-textMuted mt-1">Min 8 chars, include upper, lower, number, symbol.</p>
            </div>
          </div>
          <button type="submit" class="mt-4 inline-flex items-center gap-2 rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white shadow-card hover:shadow-lg transition">
            <i data-lucide="user-plus" class="h-5 w-5"></i>
            Create account
          </button>
        {{ form_end(form) }}
      </div>

      <div class="rounded-xl border border-border bg-white shadow-card overflow-hidden">
        <div class="flex items-center justify-between border-b border-border px-4 py-3">
          <div>
            <h2 class="text-lg font-semibold">Admin accounts</h2>
            <p class="text-xs text-textMuted">{{ admins|length }} admin{{ admins|length == 1 ? '' : 's' }}</p>
          </div>
          <span class="text-xs text-textMuted">Source: admin or staff</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs uppercase tracking-wider text-textMuted">
                <th class="border-b border-border px-4 py-3">Name</th>
                <th class="border-b border-border px-4 py-3">Email</th>
                <th class="border-b border-border px-4 py-3">Created</th>
                <th class="border-b border-border px-4 py-3">Source</th>
              </tr>
            </thead>
            <tbody>
              {% for admin in admins %}
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="border-b border-border px-4 py-3 font-medium">{{ admin.name }}</td>
                  <td class="border-b border-border px-4 py-3 text-textMuted">{{ admin.email }}</td>
                  <td class="border-b border-border px-4 py-3 text-textMuted whitespace-nowrap">{{ admin.createdAt ? admin.createdAt|date('Y-m-d') : '—' }}</td>
                  <td class="border-b border-border px-4 py-3 text-textMuted">{{ admin.source }}</td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="3" class="border-b border-border px-4 py-6 text-center text-textMuted">No admin accounts found.</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    const updatePasswordIcon = (input, btn) => {
      if (!input || !btn) return;
      const isHidden = input.type === 'password';
      btn.setAttribute('aria-label', isHidden ? 'Show password' : 'Hide password');
      const eye = btn.querySelector('.icon-eye');
      const eyeOff = btn.querySelector('.icon-eye-off');
      if (eye && eyeOff) {
        // When hidden (hashed), show closed eye; when visible, show open eye
        eye.style.display = isHidden ? 'none' : 'inline';
        eyeOff.style.display = isHidden ? 'inline' : 'none';
      }
    };

    window.togglePassword = function(targetId, btn) {
      const input = document.getElementById(targetId);
      if (!input || !btn) return;
      input.type = input.type === 'password' ? 'text' : 'password';
      updatePasswordIcon(input, btn);
    };

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-toggle-password]').forEach(btn => {
        const targetId = btn.getAttribute('data-toggle-password');
        const input = document.getElementById(targetId);
        updatePasswordIcon(input, btn);
      });
    });
  </script>
{% endblock %}


