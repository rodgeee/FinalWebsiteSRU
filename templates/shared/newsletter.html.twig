<section id="newsletter" class="lp-newsletter" aria-labelledby="newsletter-title">
  <div class="lp-newsletter__bg" aria-hidden="true"></div>
  <div class="lp-wrap lp-newsletter__grid">
    <div class="lp-newsletter__copy">
      <p class="lp-newsletter__eyebrow">First in line</p>
      <h2 id="newsletter-title" class="lp-newsletter__title">Never miss a drop.</h2>
      <p class="lp-newsletter__lead">
        Join the Shoes R’ Us list for early access to releases, members-only offers, and curated picks from the brands you follow.
      </p>
    </div>
    <form class="lp-newsletter__form" action="#" method="post">
      <label for="newsletterEmail" class="sr-only">Email address</label>
      <div class="lp-newsletter__field">
        <input id="newsletterEmail" type="email" name="email" placeholder="Your email address" autocomplete="email" required>
        <button type="submit" class="lp-newsletter__submit">Join</button>
      </div>
      <p class="lp-newsletter__fineprint">We respect your inbox. Unsubscribe anytime.</p>
    </form>
  </div>
</section>
