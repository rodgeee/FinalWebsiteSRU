{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard • Shoes R' Us{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  {# Prefer local prebuilt Tailwind; fall back to CDN if missing #}
  <script>
    (function() {
      const href = '{{ asset('styles/tailwind.css') }}';
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = href;
      link.onload = () => {};
      link.onerror = () => {
        const s = document.createElement('script');
        s.src = 'https://cdn.tailwindcss.com';
        s.onload = () => {
          if (window.tailwind) {
            window.tailwind.config = {
              theme: {
                extend: {
                  colors: {
                    brand: '#0077FF',
                    text: '#1A1A1A',
                    textMuted: '#666666',
                    card: '#F8F9FB',
                    border: '#E5E7EB'
                  },
                  fontFamily: {
                    sans: ['sans-serif'],
                    heading: ['Sora', 'sans-serif'],
                  },
                  boxShadow: { card: '0 8px 24px rgba(0,0,0,0.06)' }
                }
              }
            };
          }
        };
        document.head.appendChild(s);
      };
      document.head.appendChild(link);
    }());
  </script>
  <style>
    html, body { 
      font-family: sans-serif;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: "Sora", sans-serif;
      font-weight: 700;
    }
    /* Soft blue glow on hover for interactive elements */
    a:hover,
    button:hover,
    [role="button"]:hover,
    .hover\:glow:hover,
    .group:hover .group-hover\:glow {
      box-shadow: 0 0 0 3px rgba(0, 119, 255, 0.25) !important;
      transition: box-shadow 150ms ease;
    }
    /* Ensure cards also tint their border on hover when glow is applied */
    .hover\:glow:hover {
      border-color: #0077FF !important;
    }
  </style>
{% endblock %}

{% set stock_activity = stock_activity|default([]) %}
{% set service_activity = service_activity|default([]) %}
{% set notif_activity = notif_activity|default(stock_activity) %}
{% set notif_unread_ids = notif_unread_ids|default([]) %}
{% set notif_alert_count = notif_alert_count|default(stock_alert_count|default(0)) %}
{% set stock_alert_count = stock_alert_count|default(notif_alert_count) %}
{% block body %}
<div class="min-h-screen bg-white text-text">
  <!-- Shell -->
  <div class="grid min-h-screen grid-cols-[260px_1fr]">
    <!-- Sidebar -->
    <aside class="hidden lg:flex sticky top-0 h-screen flex-col border-r border-border bg-white">
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-3 px-5 py-4">
          <img src="{{ asset('img/shoes-r-us-logo.png') }}" class="h-10 w-auto" alt="Shoes R' Us" />
        <div>
          <p class="text-sm font-semibold leading-tight tracking-wide text-text">Shoes R' Us</p>
          {% if is_granted('ROLE_ADMIN') %}
            <p class="text-[11px] font-medium uppercase tracking-wider text-textMuted">Admin</p>
          {% else %}
            <p class="text-[11px] font-medium uppercase tracking-wider text-textMuted">Staff</p>
          {% endif %}
        </div>
      </a>
      <nav class="mt-2 flex-1 space-y-2 px-2">
        {% set currentRoute = app.request.attributes.get('d_route') %}
        {# Helper macro-like snippet for links #}
        <a href="{{ path('app_dashboard') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute == 'app_dashboard' %}aria-current="page"{% endif %}>
          <i data-lucide="layout-dashboard" class="h-5 w-5 text-gray-500 group-aria-[current=page]:text-brand group-hover:text-brand"></i>
          <span>Dashboard</span>
        </a>
        <a href="{{ path('admin_products_index') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_products_' %}aria-current="page"{% endif %}>
          <i data-lucide="shopping-bag" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Products</span>
        </a>
        <a href="{{ path('admin_orders_index') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_orders_' %}aria-current="page"{% endif %}>
          <i data-lucide="package" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Orders</span>
        </a>
        <a href="{{ path('admin_transactions_index') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_transactions_' %}aria-current="page"{% endif %}>
          <i data-lucide="wallet" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Transactions</span>
        </a>
        <a href="{{ path('admin_stocks_index') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_stocks_' %}aria-current="page"{% endif %}>
          <i data-lucide="package-check" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Stocks</span>
        </a>
        <a href="{{ path('admin_service_index') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_service_' %}aria-current="page"{% endif %}>
          <i data-lucide="life-buoy" class="h-5 w-5 text-gray-500 group-hover:text-brand group-aria-[current=page]:text-brand"></i>
          <span>Service</span>
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_activity_log') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_activity_log' %}aria-current="page"{% endif %}>
          <i data-lucide="activity" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Activity Log</span>
        </a>
        <a href="{{ path('admin_staff_index') }}" class="group flex items-center gap-3 rounded-xl px-3 py-3 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent aria-[current=page]:bg-[#E8F2FF] aria-[current=page]:text-brand aria-[current=page]:border-brand" {% if currentRoute starts with 'admin_staff_' %}aria-current="page"{% endif %}>
          <i data-lucide="users" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>User Management</span>
        </a>
        {% endif %}
        {#
        <a href="/admin/customers" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="users" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Customers</span>
        </a>
        <a href="/admin/analytics" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="bar-chart-3" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Sales & Analytics</span>
        </a>
        <a href="/admin/marketing" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="megaphone" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Marketing</span>
        </a>
        <a href="/admin/promotions" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="badge-percent" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Promotions</span>
        </a>
        <a href="/admin/releases" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="calendar-days" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Releases / Drops</span>
        </a>
        <a href="/admin/media" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="image" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Media Library</span>
        </a>
        <a href="/admin/settings" class="group flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-text hover:bg-[#E8F2FF] hover:text-brand transition-all duration-200 ease-in-out border-l-4 border-transparent">
          <i data-lucide="settings" class="h-5 w-5 text-gray-500 group-hover:text-brand"></i>
          <span>Settings</span>
        </a>
        #}
      </nav>
      <div class="mt-auto p-3 text-[11px] text-textMuted">© {{ "now"|date('Y') }} Shoes R' Us</div>
    </aside>

    <!-- Main column -->
    <div class="flex min-h-screen flex-col">
      <!-- Top navbar -->
      <header class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-border">
        <div class="flex items-center gap-3 px-4 py-3">
          <!-- Mobile: open sidebar button -->
          <button id="btnOpenSidebar" class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border text-gray-600 hover:text-brand hover:border-brand transition-all" aria-label="Open sidebar">
            <i data-lucide="menu" class="h-5 w-5"></i>
          </button>

          <!-- Search -->
          <form method="get" action="{{ path('app_dashboard') }}" class="relative ml-1 flex-1 max-w-5xl">
            <input type="hidden" name="status" value="{{ status|default('All') }}">
            <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400"></i>
            <input type="search" name="search" value="{{ search_term|default('') }}" placeholder="Search products or orders..." class="w-full rounded-2xl border border-gray-300 pl-10 pr-10 py-3 text-base placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-all" />
            {% if search_term|default('') %}
              <button type="button" onclick="this.form.search.value=''; this.form.submit();" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-brand" aria-label="Clear search">
                <i data-lucide="x" class="h-4 w-4"></i>
              </button>
            {% endif %}
          </form>

          <!-- Actions -->
          <div class="ml-auto flex items-center gap-2">
            {% set stockAlertCount = notif_alert_count|default(0) %}
            <div class="relative" id="stockNotifications">
              <button class="relative inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border text-gray-600 hover:text-brand hover:border-brand transition-all bg-white" aria-label="View stock notifications" title="View stock notifications" data-toggle="stock">
                <i data-lucide="bell" class="h-5 w-5"></i>
                {% if stockAlertCount > 0 %}
                  <span class="absolute -right-1 -top-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-brand px-1 text-[10px] font-bold text-white">{{ stockAlertCount }}</span>
                {% endif %}
              </button>
              <div class="invisible absolute right-0 mt-2 w-72 translate-y-1 rounded-xl border border-border bg-white p-2 shadow-md opacity-0 transition-all duration-200 ease-in-out max-h-[360px] overflow-y-auto" data-menu="stock">
                <div class="px-3 pb-2 text-xs uppercase tracking-[3px] text-textMuted">Recent updates</div>
                {% for log in notif_activity %}
                  {% set isUnread = log.id in notif_unread_ids %}
                  <a href="{{ path('notification_go', {id: log.id}) }}" class="block rounded-lg px-3 py-2 hover:bg-card transition {{ isUnread ? 'bg-brand/5' : '' }}">
                    <div class="flex items-start gap-2">
                      <span class="inline-flex rounded-full bg-brand/10 px-2 py-0.5 text-[11px] font-semibold text-brand uppercase">
                        {{ log.entityType|default('stock')|capitalize }}
                      </span>
                      <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-semibold text-gray-700 uppercase">
                        {{ log.action|default('update')|capitalize }}
                      </span>
                      <div class="flex-1">
                        <p class="text-sm font-semibold leading-tight text-text">{{ log.description ?? 'Stock change' }}</p>
                        <p class="text-xs text-textMuted leading-tight">
                          {{ log.actorName ?? 'Someone' }} • {{ log.createdAt ? log.createdAt|date('M d, H:i') : '—' }}
                        </p>
                      </div>
                    </div>
                  </a>
                {% else %}
                  <div class="px-3 py-2 text-sm text-textMuted">No recent stock updates.</div>
                {% endfor %}
              </div>
            </div>

            <div class="relative" id="profileMenu">
              <button class="inline-flex items-center gap-2 rounded-xl border border-border px-2 py-1.5 text-sm font-medium text-gray-700 hover:text-brand hover:border-brand transition-all bg-white" data-toggle="profile">
                <i data-lucide="user-circle" class="h-6 w-6"></i>
                <i data-lucide="chevron-down" class="h-4 w-4"></i>
              </button>
              <div class="invisible absolute right-0 mt-2 w-44 translate-y-1 rounded-xl border border-border bg-white p-2 shadow-md opacity-0 transition-all duration-200 ease-in-out" data-menu="profile">
                {% if app.user %}
                <div class="px-3 py-2 text-xs border-b border-border mb-1">
                  <div class="text-[13px] font-semibold text-text">{{ app.user.getUsername() }}</div>
                  <div class="text-[11px] text-textMuted">{{ app.user.userIdentifier }}</div>
                </div>
                {% endif %}
                <a href="{{ path('app_profile') }}" class="block w-full rounded-lg px-3 py-2 text-left text-sm hover:bg-card">Profile</a>
                <form method="post" action="{{ path('adminls_logout') }}">
                  <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                  <button type="submit" class="block w-full rounded-lg px-3 py-2 text-left text-sm hover:bg-card">Logout</button>
                </form>
              </div>
            </div>

          </div>
        </div>
      </header>

      <!-- Main content area -->
      <main class="flex-1 bg-card/50 p-4 sm:p-6">
        {% block dashboard_content %}
        <div class="mx-auto max-w-[1200px] space-y-6">
          
          <!-- Flash Messages -->
          {% for message in app.flashes('success') %}
            <div class="rounded-xl bg-green-50 border border-green-200 p-4 text-green-800">
              {{ message }}
            </div>
          {% endfor %}
          
          <div class="flex items-center justify-between">
            <div>
              <h1 class="text-2xl font-semibold">Dashboard</h1>
              {% if app.user %}
                {% set roleLabel = is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' %}
                <p class="text-sm text-textMuted">Welcome back, {{ roleLabel }} {{ app.user.getUsername() }} ({{ app.user.userIdentifier }})!</p>
              {% endif %}
            </div>
          </div>

          {% if search_term|default('') %}
          <section class="rounded-xl border border-border bg-white shadow-card p-4 space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs uppercase tracking-[3px] text-textMuted">Search results</p>
                <h2 class="text-lg font-semibold">“{{ search_term }}”</h2>
              </div>
              <a href="{{ path('app_dashboard', {status: status|default('All')}) }}" class="text-sm text-brand hover:underline">Clear search</a>
            </div>
            <div class="grid gap-4 lg:grid-cols-2">
              <div>
                <h3 class="text-sm font-semibold text-textMuted uppercase tracking-[3px] mb-2">Products</h3>
                <div class="space-y-2">
                  {% for product in search_results.products %}
                    <a href="{{ path('admin_products_show', {id: product.id}) }}" class="flex items-start gap-3 rounded-lg border border-border px-3 py-2 hover:border-brand hover:bg-[#E8F2FF]/50 transition">
                      <div class="flex-1">
                        <p class="font-semibold text-sm">{{ product.name }}</p>
                        <p class="text-xs text-textMuted">{{ product.color }} • {{ product.size }}</p>
                      </div>
                      <span class="text-xs text-brand font-semibold">View</span>
                    </a>
                  {% else %}
                    <p class="text-sm text-textMuted">No products matched.</p>
                  {% endfor %}
                </div>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-textMuted uppercase tracking-[3px] mb-2">Orders</h3>
                <div class="space-y-2">
                  {% for order in search_results.orders %}
                    <a href="{{ path('admin_orders_show', {id: order.id}) }}" class="flex items-start gap-3 rounded-lg border border-border px-3 py-2 hover:border-brand hover:bg-[#E8F2FF]/50 transition">
                      <div class="flex-1">
                        <p class="font-semibold text-sm">{{ order.displayOrderNumber }}</p>
                        <p class="text-xs text-textMuted">{{ order.customerName }} • {{ order.orderStatus }}</p>
                      </div>
                      <span class="text-xs text-brand font-semibold">View</span>
                    </a>
                  {% else %}
                    <p class="text-sm text-textMuted">No orders matched.</p>
                  {% endfor %}
                </div>
              </div>
            </div>
          </section>
          {% endif %}

          <!-- Cards: admins see all, staff see only Products / Orders / Services -->
          {% if is_granted('ROLE_ADMIN') %}
            <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Total users</p>
                <p class="mt-2 text-xl font-bold">{{ stats.users ?? '—' }}</p>
                <p class="mt-1 text-xs text-textMuted">Admins {{ stats.admins ?? 0 }} • Staff {{ stats.staff ?? 0 }}</p>
              </div>
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Products</p>
                <p class="mt-2 text-xl font-bold">{{ stats.products ?? '—' }}</p>
                <p class="mt-1 text-xs text-textMuted">Catalog items</p>
              </div>
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Orders</p>
                <p class="mt-2 text-xl font-bold">{{ stats.orders ?? '—' }}</p>
                <p class="mt-1 text-xs text-textMuted">All time</p>
              </div>
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Services / Stocks</p>
                <p class="mt-2 text-xl font-bold">{{ stats.services ?? 0 }} services</p>
                <p class="mt-1 text-xs text-textMuted">{{ stats.stocks ?? 0 }} stock entries</p>
              </div>
            </section>
          {% else %}
            <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Products</p>
                <p class="mt-2 text-xl font-bold">{{ stats.products ?? '—' }}</p>
                <p class="mt-1 text-xs text-textMuted">Catalog items</p>
              </div>
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Orders</p>
                <p class="mt-2 text-xl font-bold">{{ stats.orders ?? '—' }}</p>
                <p class="mt-1 text-xs text-textMuted">All time</p>
              </div>
              <div class="rounded-xl border border-border bg-white p-4 shadow-card transition-all hover:shadow-lg hover:glow">
                <p class="text-xs font-semibold uppercase tracking-wider text-textMuted">Services</p>
                <p class="mt-2 text-xl font-bold">{{ stats.services ?? 0 }} services</p>
                <p class="mt-1 text-xs text-textMuted">Service offerings</p>
              </div>
            </section>
          {% endif %}

          <section class="rounded-xl border border-border bg-white shadow-card">
            <div class="flex items-center justify-between border-b border-border p-4">
              <h2 class="text-lg font-semibold">Recent Orders</h2>
              <form method="get" action="{{ path('app_dashboard') }}">
                <select name="status" class="rounded-lg border border-gray-300 px-3 py-2 text-sm bg-white text-text focus:border-brand focus:outline-none" onchange="this.form.submit()">
                  {% set statuses = ['All','Pending','Processing','Shipped','Delivered','Cancelled'] %}
                  {% for s in statuses %}
                    <option value="{{ s }}" {{ s == status ? 'selected' : '' }}>{{ s }}</option>
                  {% endfor %}
                </select>
              </form>
            </div>
            <div class="overflow-x-auto p-2">
              <table class="w-full border-separate border-spacing-0 text-sm">
                <thead>
                  <tr class="text-left text-xs uppercase tracking-wider text-textMuted dark:text-slate-400">
                    <th class="border-b border-border px-4 py-3">Order ID</th>
                    <th class="border-b border-border px-4 py-3">Customer</th>
                    <th class="border-b border-border px-4 py-3">Status</th>
                    <th class="border-b border-border px-4 py-3">Total</th>
                    <th class="border-b border-border px-4 py-3">Date</th>
                  </tr>
                </thead>
                <tbody>
                  {% for o in recent_orders %}
                    <tr>
                      <td class="border-b border-border px-4 py-3">#{{ o.id }}</td>
                      <td class="border-b border-border px-4 py-3">{{ o.customerName }}</td>
                      <td class="border-b border-border px-4 py-3">{{ o.orderStatus }}</td>
                      <td class="border-b border-border px-4 py-3">{{ o.totalPrice ? ('₱' ~ o.totalPrice) : '—' }}</td>
                      <td class="border-b border-border px-4 py-3">{{ o.dateCreated ? o.dateCreated|date('Y-m-d H:i') : '—' }}</td>
                    </tr>
                  {% else %}
                    <tr>
                      <td colspan="5" class="border-b border-border px-4 py-6 text-center text-sm text-textMuted">No recent orders yet</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </section>

          {% if is_granted('ROLE_ADMIN') %}
            <section class="rounded-xl border border-border bg-white shadow-card">
              <div class="flex items-center justify-between border-b border-border p-4">
                <h2 class="text-lg font-semibold">Recent activity</h2>
                <a href="{{ path('admin_activity_log') }}" class="text-sm text-brand hover:underline">View full log</a>
              </div>
              <div class="divide-y divide-border">
                {% for log in recent_activity %}
                  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-3">
                    <div>
                      <p class="text-sm font-semibold">{{ log.actorName ?? 'Unknown user' }}</p>
                      <p class="text-xs text-textMuted">{{ log.actorEmail ?? '—' }} • {{ log.actorRole ?? '—' }}</p>
                    </div>
                    <div class="text-sm text-textMuted">
                      <span class="font-semibold text-text">{{ log.action|capitalize }}</span>
                      on {{ log.entityType|capitalize }} #{{ log.entityId ?? '—' }}
                    </div>
                    <div class="text-xs text-textMuted whitespace-nowrap">{{ log.createdAt ? log.createdAt|date('Y-m-d H:i') : '—' }}</div>
                  </div>
                {% else %}
                  <div class="px-4 py-5 text-sm text-textMuted">No recent activity recorded.</div>
                {% endfor %}
              </div>
            </section>
          {% endif %}
        </div>
        {% endblock %}
      </main>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    // Render icons
    document.addEventListener('DOMContentLoaded', () => {
      window.lucide?.createIcons();

      // Simple dropdown toggles
      function bindDropdown(rootId) {
        const root = document.getElementById(rootId);
        if (!root) return;
        const btn = root.querySelector('[data-toggle]');
        const menu = root.querySelector('[data-menu]');
        if (!btn || !menu) return;
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = menu.classList.contains('opacity-100');
          document.querySelectorAll('[data-menu]')
            .forEach(m => m.classList.add('invisible','opacity-0','translate-y-1'));
          if (!open) menu.classList.remove('invisible','opacity-0','translate-y-1');
          if (!open) menu.classList.add('opacity-100');
        });
        document.addEventListener('click', () => menu.classList.add('invisible','opacity-0','translate-y-1'));
      }
      bindDropdown('stockNotifications');
      bindDropdown('profileMenu');

    });
  </script>
{% endblock %}


