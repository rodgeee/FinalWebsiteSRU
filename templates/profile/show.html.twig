{% extends 'dashboard/index.html.twig' %}

{% block title %}Profile • Admin{% endblock %}

{% block dashboard_content %}
<div class="mx-auto max-w-[1000px] p-4 sm:p-6 space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-xs uppercase tracking-[3px] text-textMuted">Account Management</p>
      <h1 class="text-2xl font-semibold">My Profile</h1>
    </div>
    <div class="flex items-center gap-3">
      <a href="{{ path('app_profile_edit') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2 text-sm font-medium text-gray-700 hover:bg-[#E8F2FF] hover:text-brand hover:border-brand transition-all">
        <i data-lucide="edit-3" class="h-4 w-4"></i>
        Edit Profile
      </a>
      <a href="{{ path('app_dashboard') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-3 py-2 text-sm font-medium text-gray-700 hover:bg-[#E8F2FF] hover:text-brand hover:border-brand transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline><path d="M20 12H10"></path></svg>
        Back
      </a>
    </div>
  </div>

  {% for message in app.flashes('success') %}
    <div class="rounded-xl bg-green-50 border border-green-200 p-4 text-green-800">{{ message }}</div>
  {% endfor %}

  <!-- Profile Header -->
  <div class="rounded-xl border border-border bg-white shadow-card p-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <div class="flex-1">
        {% set fullField = attribute(user, 'Fullname') is defined ? attribute(user, 'Fullname') : (attribute(user, 'fullName') is defined ? attribute(user, 'fullName') : '') %}
        {% set emailField = attribute(user, 'Email') is defined ? attribute(user, 'Email') : (attribute(user, 'email') is defined ? attribute(user, 'email') : '') %}
        <h2 class="text-2xl font-bold text-text mb-1">{{ fullField }}</h2>
        <p class="text-textMuted mb-3">{{ emailField }}</p>
        <div class="flex items-center gap-4 flex-wrap">
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand/10 text-brand text-sm font-semibold">
              <i data-lucide="shield-check" class="h-4 w-4"></i>
              {% for role in user.roles %}
                {{ role|replace({'ROLE_': ''}) }}
              {% endfor %}
            </span>
          </div>
          <div class="flex items-center gap-2 text-sm text-textMuted">
            <i data-lucide="user" class="h-4 w-4"></i>
            <span>{{ fullField ?: 'User' }}</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-textMuted">
            <i data-lucide="hash" class="h-4 w-4"></i>
            <span>ID: #{{ user.id }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Information Cards Grid -->
  <div class="grid gap-6 md:grid-cols-2">
    <!-- Account Information Card -->
    <div class="rounded-xl border border-border bg-white shadow-card p-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-[#E8F2FF] flex items-center justify-center">
          <i data-lucide="user-circle" class="h-5 w-5 text-brand"></i>
        </div>
        <h2 class="text-lg font-semibold text-text">Account Information</h2>
      </div>
      <div class="space-y-5">
        <div class="pb-4 border-b border-border last:border-0 last:pb-0">
          <p class="text-xs uppercase tracking-[2px] text-textMuted mb-2">Full Name</p>
          <p class="text-base font-medium text-text">{{ fullField }}</p>
        </div>
        <div class="pb-4 border-b border-border last:border-0 last:pb-0">
          <p class="text-xs uppercase tracking-[2px] text-textMuted mb-2">Email Address</p>
          <p class="text-base font-medium text-text break-all">{{ emailField }}</p>
        </div>
        <div class="pb-4 border-b border-border last:border-0 last:pb-0">
          <p class="text-xs uppercase tracking-[2px] text-textMuted mb-2">Role</p>
          <div class="flex items-center gap-2">
            {% for role in user.roles %}
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[#E8F2FF] text-brand text-sm font-semibold">
                <i data-lucide="shield-check" class="h-3.5 w-3.5"></i>
                {{ role|replace({'ROLE_': ''}) }}
              </span>
            {% endfor %}
          </div>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[2px] text-textMuted mb-2">User ID</p>
          <p class="text-base font-medium text-text">#{{ user.id }}</p>
        </div>
      </div>
    </div>

    <!-- Security Card -->
    <div class="rounded-xl border border-border bg-white shadow-card p-6">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-[#E8F2FF] flex items-center justify-center">
          <i data-lucide="shield" class="h-5 w-5 text-brand"></i>
        </div>
        <h2 class="text-lg font-semibold text-text">Account Security</h2>
      </div>
      <div class="space-y-5">
        <div class="pb-4 border-b border-border">
          <p class="text-xs uppercase tracking-[2px] text-textMuted mb-2">Password</p>
          <div class="flex items-center gap-2">
            <span class="text-lg tracking-widest">••••••••</span>
            <span class="text-xs text-textMuted">Active</span>
          </div>
          <p class="text-xs text-textMuted mt-2">Last updated: Hidden for security</p>
        </div>
        <div class="pt-2">
          <a href="{{ path('app_profile_edit') }}" class="inline-flex items-center gap-2 rounded-lg bg-[#E8F2FF] hover:bg-[#D0E5FF] text-brand px-4 py-2 text-sm font-medium transition-all">
            <i data-lucide="key" class="h-4 w-4"></i>
            Change Password
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}

