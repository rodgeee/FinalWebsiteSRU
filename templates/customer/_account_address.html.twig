<section class="lp-account__panel {{ activeTab == 'address' ? 'is-active' : '' }}" id="address" aria-labelledby="address-heading">
  <p class="lp-account__panel-lead" id="address-heading">
    Save your addresses to make checkout faster.
  </p>

  <div class="lp-account-addresses">
    {% for address in addresses %}
      <article class="lp-account-address-card">
        <header class="lp-account-address-card__head">
          <div class="lp-account-address-card__title-row">
            <h2 class="lp-account-address-card__label">{{ address.label }}</h2>
            {% if address.isDefault %}
              <span class="lp-account-address-card__divider" aria-hidden="true">|</span>
              <span class="lp-account-address-card__badge">Default Address</span>
            {% endif %}
          </div>
          <div class="lp-account-address-card__actions">
            <a
              href="{{ path('customer_account', {tab: 'address', edit_address: address.id}) }}"
              class="lp-account-address-card__icon-btn"
              aria-label="Edit {{ address.label }} address"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 20h9" stroke-linecap="round"/>
                <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" stroke-linejoin="round"/>
              </svg>
            </a>
            <form method="post" action="{{ path('customer_account', {tab: 'address'}) }}" data-turbo="false" class="lp-account-address-card__delete-form">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token('customer_address_delete_' ~ address.id) }}">
              <input type="hidden" name="form_type" value="address_delete">
              <input type="hidden" name="address_id" value="{{ address.id }}">
              <button type="submit" class="lp-account-address-card__icon-btn" aria-label="Delete {{ address.label }} address">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M3 6h18" stroke-linecap="round"/>
                  <path d="M8 6V4h8v2M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" stroke-linejoin="round"/>
                  <path d="M10 11v6M14 11v6" stroke-linecap="round"/>
                </svg>
              </button>
            </form>
          </div>
        </header>
        <div class="lp-account-address-card__body">
          <p class="lp-account-address-card__line">{{ address.displayLine1 }}</p>
          {% if address.displayLine2 %}
            <p class="lp-account-address-card__line">{{ address.displayLine2 }}</p>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>

  {% if addressForm %}
    <div class="lp-account-address-form-wrap" id="address-form">
      <h3 class="lp-account-address-form__title">{{ addressForm.id ? 'Edit address' : 'New address' }}</h3>
      <form class="lp-account-form lp-account-address-form" method="post" action="{{ path('customer_account', {tab: 'address'}) }}" data-turbo="false">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('customer_account') }}">
        <input type="hidden" name="form_type" value="address">
        {% if addressForm.id %}
          <input type="hidden" name="address_id" value="{{ addressForm.id }}">
        {% endif %}

        <div class="lp-account-form__row lp-account-form__row--2">
          <div class="lp-account-form__field">
            <label for="address_label">Label</label>
            <select class="lp-account-form__select" id="address_label" name="address_label">
              {% for option in ['Home', 'Work', 'Other'] %}
                <option value="{{ option }}" {{ addressForm.label == option ? 'selected' : '' }}>{{ option }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="lp-account-form__field lp-account-form__field--checkbox">
            <label class="lp-account-address-form__check">
              <input type="checkbox" name="address_default" value="1" {{ addressForm.isDefault ? 'checked' : '' }}>
              <span>Set as default address</span>
            </label>
          </div>
        </div>

        <div class="lp-account-form__field">
          <label for="address_line1">Street address</label>
          <input class="lp-account-form__input" type="text" id="address_line1" name="address_line1" value="{{ addressForm.addressLine1 }}" required autocomplete="address-line1">
        </div>

        <div class="lp-account-form__field">
          <label for="address_line2">Apartment, suite, etc. (optional)</label>
          <input class="lp-account-form__input" type="text" id="address_line2" name="address_line2" value="{{ addressForm.addressLine2 }}" autocomplete="address-line2">
        </div>

        <div class="lp-account-form__row lp-account-form__row--2">
          <div class="lp-account-form__field">
            <label for="address_city">City</label>
            <input class="lp-account-form__input" type="text" id="address_city" name="address_city" value="{{ addressForm.city }}" required autocomplete="address-level2">
          </div>
          <div class="lp-account-form__field">
            <label for="address_province">Province / state</label>
            <input class="lp-account-form__input" type="text" id="address_province" name="address_province" value="{{ addressForm.province }}" autocomplete="address-level1">
          </div>
        </div>

        <div class="lp-account-form__row lp-account-form__row--2">
          <div class="lp-account-form__field">
            <label for="address_postal">Postal code</label>
            <input class="lp-account-form__input" type="text" id="address_postal" name="address_postal" value="{{ addressForm.postalCode }}" autocomplete="postal-code">
          </div>
          <div class="lp-account-form__field">
            <label for="address_country">Country</label>
            <input class="lp-account-form__input" type="text" id="address_country" name="address_country" value="{{ addressForm.country }}" required autocomplete="country-name">
          </div>
        </div>

        <div class="lp-account-form__row lp-account-form__row--2">
          <div class="lp-account-form__field">
            <label for="address_email">Contact email</label>
            <input class="lp-account-form__input" type="email" id="address_email" name="address_email" value="{{ addressForm.contactEmail }}" autocomplete="email">
          </div>
          <div class="lp-account-form__field">
            <label for="address_phone">Contact phone</label>
            <input class="lp-account-form__input" type="tel" id="address_phone" name="address_phone" value="{{ addressForm.contactPhone }}" autocomplete="tel">
          </div>
        </div>

        <div class="lp-account-form__actions lp-account-address-form__actions">
          <button type="submit" class="lp-account-form__save">Save</button>
          <a href="{{ path('customer_account', {tab: 'address'}) }}" class="lp-account-address-form__cancel">Cancel</a>
        </div>
      </form>
    </div>
  {% else %}
    <div class="lp-account-addresses__footer">
      <a href="{{ path('customer_account', {tab: 'address', new_address: 1}) }}#address-form" class="lp-account-addresses__add">
        Add new address
      </a>
    </div>
  {% endif %}
</section>
